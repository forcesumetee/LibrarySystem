<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================
         Anuphan (OFL) bundled font — single family, weight-selected.
         Mono uses system Consolas to echo the IBM Plex Mono in the mockup
         (reg numbers / shelf codes) without bundling another face.
         ============================================================ -->
    <FontFamily x:Key="AppFontFamily">pack://application:,,,/Assets/Fonts/#Anuphan</FontFamily>
    <FontFamily x:Key="MonoFontFamily">Consolas, Cascadia Mono, monospace</FontFamily>

    <!-- Portrait design canvas -->
    <sys:Double x:Key="CanvasWidth">1080</sys:Double>
    <sys:Double x:Key="CanvasHeight">1920</sys:Double>

    <!-- ===== Palette (from Claude Design mockup tokens) ===== -->
    <Color x:Key="PrimaryColor">#1F5AA8</Color>
    <Color x:Key="PrimaryDarkColor">#17467F</Color>
    <Color x:Key="PrimaryTintColor">#EAF1FA</Color>
    <!-- Foreground for text/icons that sit ON the primary fill (buttons, selected chip).
         Default white; ThemeService recomputes it (white vs dark) from the chosen primary's
         luminance at startup + on live change, so any picked colour stays readable. -->
    <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
    <Color x:Key="AccentColor">#E0922E</Color>
    <Color x:Key="SuccessColor">#2E9C7E</Color>
    <Color x:Key="ErrorColor">#D2544A</Color>
    <Color x:Key="PanelColor">#F1F5FA</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="DarkColor">#16305A</Color>
    <Color x:Key="HeaderDarkColor">#13294D</Color>
    <Color x:Key="TextColor">#1A2532</Color>
    <Color x:Key="TextSecondColor">#515E70</Color>
    <Color x:Key="MutedColor">#9AA6B5</Color>
    <Color x:Key="BorderColor">#E2E8F1</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}" />
    <SolidColorBrush x:Key="PrimaryTintBrush" Color="{StaticResource PrimaryTintColor}" />
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="{StaticResource OnPrimaryColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextSecondBrush" Color="{StaticResource TextSecondColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />

    <!-- Branding-absent fallback background (mockup kiosk gradient) -->
    <LinearGradientBrush x:Key="BackgroundGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#13294D" Offset="0" />
        <GradientStop Color="#1F5AA8" Offset="0.52" />
        <GradientStop Color="#2E8B86" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
