<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Anuphan (OFL) bundled font. Single family "Anuphan" with
         Regular/Medium/SemiBold/Bold faces — select via FontWeight.
         ============================================================ -->
    <FontFamily x:Key="AppFontFamily">pack://application:,,,/Assets/Fonts/#Anuphan</FontFamily>

    <!-- Design canvas dimensions (portrait kiosk) -->
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="CanvasWidth">1080</sys:Double>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="CanvasHeight">1920</sys:Double>

    <!-- Brand palette (placeholder neutrals; refined against mockup in Phase 4) -->
    <Color x:Key="BrandBackgroundColor">#0F1115</Color>
    <Color x:Key="BrandSurfaceColor">#1A1D24</Color>
    <Color x:Key="BrandTextColor">#F2F4F8</Color>
    <Color x:Key="BrandMutedColor">#9AA3B2</Color>
    <Color x:Key="BrandAccentColor">#4C8DFF</Color>

    <SolidColorBrush x:Key="BrandBackgroundBrush" Color="{StaticResource BrandBackgroundColor}" />
    <SolidColorBrush x:Key="BrandSurfaceBrush" Color="{StaticResource BrandSurfaceColor}" />
    <SolidColorBrush x:Key="BrandTextBrush" Color="{StaticResource BrandTextColor}" />
    <SolidColorBrush x:Key="BrandMutedBrush" Color="{StaticResource BrandMutedColor}" />
    <SolidColorBrush x:Key="BrandAccentBrush" Color="{StaticResource BrandAccentColor}" />

    <!-- App-wide default text style: Anuphan as primary font -->
    <Style TargetType="{x:Type Control}" x:Key="BaseControlStyle">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
    </Style>

</ResourceDictionary>
