<Window x:Class="LibraryKiosk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:LibraryKiosk.Services"
        Title="Library Kiosk"
        Height="960" Width="540"
        MinHeight="480" MinWidth="270"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        FontFamily="{StaticResource AppFontFamily}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <!-- ============================================================
         Kiosk shell. UI authored on a fixed 1080 x 1920 portrait
         design canvas, scaled to the window with a Uniform Viewbox.
         ============================================================ -->
    <Viewbox Stretch="Uniform" StretchDirection="Both">
        <Grid x:Name="DesignCanvas"
              Width="1080" Height="1920"
              Background="{StaticResource BrandBackgroundBrush}">

            <!-- Branding background (decoded from bytes, cache-busted). Proves
                 the image-load path: change it in admin-pc -> kiosk updates. -->
            <Image Source="{Binding BackgroundImage}"
                   Stretch="UniformToFill"
                   Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />
            <!-- Scrim so foreground text stays legible over any background. -->
            <Border Background="#A60F1115"
                    Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />

            <!-- Phase 3 temporary home: connection state + counts + branding. -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="900">

                <!-- Branding logo -->
                <Image Source="{Binding LogoImage}"
                       Stretch="Uniform" MaxHeight="240" Margin="0,0,0,48"
                       HorizontalAlignment="Center" />

                <TextBlock Text="LibraryKiosk"
                           FontWeight="Bold" FontSize="84"
                           Foreground="{StaticResource BrandTextBrush}"
                           HorizontalAlignment="Center" />

                <!-- Status card -->
                <Border Background="#CC1A1D24"
                        CornerRadius="28" Padding="56,48" Margin="0,56,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,20,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource BrandMutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding State}" Value="{x:Static svc:ConnectionState.Connected}">
                                                <Setter Property="Fill" Value="#3FB950" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding State}" Value="{x:Static svc:ConnectionState.Unlicensed}">
                                                <Setter Property="Fill" Value="#E3B341" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding State}" Value="{x:Static svc:ConnectionState.Unreachable}">
                                                <Setter Property="Fill" Value="#F85149" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding StatusHeader}"
                                       FontWeight="SemiBold" FontSize="46"
                                       TextWrapping="Wrap" MaxWidth="720"
                                       Foreground="{StaticResource BrandTextBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <TextBlock Text="{Binding StatusDetail}"
                                   FontWeight="Regular" FontSize="30"
                                   Foreground="{StaticResource BrandMutedBrush}"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="0,18,0,0" />

                        <!-- Connected details -->
                        <StackPanel Margin="0,44,0,0"
                                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                            <TextBlock HorizontalAlignment="Center">
                                <Run Text="หนังสือในระบบ " FontSize="34" Foreground="#9AA3B2" />
                                <Run Text="{Binding BookCount, Mode=OneWay}" FontSize="68" FontWeight="Bold" Foreground="#F2F4F8" />
                                <Run Text=" เล่ม" FontSize="34" Foreground="#9AA3B2" />
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0"
                                       FontSize="30" Foreground="{StaticResource BrandMutedBrush}">
                                <Run Text="โหลดเข้าหน่วยความจำ " />
                                <Run Text="{Binding LoadedBookCount, Mode=OneWay}" Foreground="#F2F4F8" />
                                <Run Text=" รายการ • " />
                                <Run Text="{Binding CategoryCount, Mode=OneWay}" Foreground="#F2F4F8" />
                                <Run Text=" หมวด" />
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Center" Margin="0,16,0,0"
                                       FontSize="28" Foreground="{StaticResource BrandMutedBrush}">
                                <Run Text="อัปเดตล่าสุด: " />
                                <Run Text="{Binding LastUpdated, Mode=OneWay}" Foreground="#F2F4F8" />
                            </TextBlock>
                        </StackPanel>

                        <TextBlock Text="กำลังโหลด…"
                                   FontSize="32" Foreground="{StaticResource BrandAccentBrush}"
                                   HorizontalAlignment="Center" Margin="0,36,0,0"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>

                <Button Content="ลองใหม่"
                        Command="{Binding RefreshCommand}"
                        FontFamily="{StaticResource AppFontFamily}"
                        FontWeight="SemiBold" FontSize="40"
                        Foreground="White" Background="{StaticResource BrandAccentBrush}"
                        BorderThickness="0" Cursor="Hand"
                        Padding="64,24" Margin="0,56,0,0"
                        HorizontalAlignment="Center">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20" />
                        </Style>
                    </Button.Resources>
                </Button>

            </StackPanel>
        </Grid>
    </Viewbox>
</Window>
