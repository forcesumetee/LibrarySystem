<Window x:Class="LibraryKiosk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LibraryKiosk.ViewModels"
        xmlns:conv="clr-namespace:LibraryKiosk.Utils"
        Title="Library Kiosk"
        Height="960" Width="540"
        MinHeight="480" MinWidth="270"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        FontFamily="{StaticResource AppFontFamily}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:InverseBooleanConverter x:Key="InvBool" />
        <conv:StringToVisibilityConverter x:Key="StrToVis" />

        <!-- Book card button -->
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardRoot" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="20" SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="360" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Cover -->
                                <Border Grid.Row="0" CornerRadius="20,20,0,0" ClipToBounds="True"
                                        Background="{Binding PlaceholderBrush}">
                                    <Grid>
                                        <Image Source="{Binding Cover}" Stretch="UniformToFill"
                                               Visibility="{Binding HasCover, Converter={StaticResource BoolToVis}}" />
                                        <!-- bottom scrim for title legibility -->
                                        <Border VerticalAlignment="Bottom" Height="170">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#00000000" Offset="0" />
                                                    <GradientStop Color="#CC000000" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel VerticalAlignment="Bottom" Margin="20,0,20,16">
                                            <TextBlock Text="{Binding Title}" Foreground="White"
                                                       FontWeight="Bold" FontSize="30" TextWrapping="Wrap"
                                                       MaxHeight="118" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Publisher}" Foreground="#D8FFFFFF"
                                                       FontWeight="Regular" FontSize="22" Margin="0,4,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding HasPublisher, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Meta -->
                                <StackPanel Grid.Row="1" Margin="18,14,18,16">
                                    <TextBlock Text="{Binding RegNo}" FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="24" Foreground="{StaticResource MutedBrush}" />
                                    <Grid Margin="0,12,0,0">
                                        <Border HorizontalAlignment="Left" CornerRadius="999"
                                                Background="{StaticResource PrimaryTintBrush}" Padding="14,7">
                                            <TextBlock Text="{Binding Category}" FontWeight="SemiBold" FontSize="22"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="180" />
                                        </Border>
                                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontFamily="{StaticResource MonoFontFamily}" FontSize="24"
                                                   Foreground="{StaticResource TextSecondBrush}"
                                                   Text="{Binding Shelf}"
                                                   Visibility="{Binding HasShelf, Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardRoot" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="CardRoot" Property="BorderThickness" Value="3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary pill button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="40" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{StaticResource PrimaryBrush}" CornerRadius="20"
                                Padding="56,22" MinHeight="88">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Settings gear (three dots) — reused in header + stuck-state overlays -->
        <Style x:Key="GearButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="88" />
            <Setter Property="Height" Value="88" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#26FFFFFF" CornerRadius="44" BorderBrush="#40FFFFFF" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Width="9" Height="9" Fill="White" Margin="0,0,0,5" />
                                <Ellipse Width="9" Height="9" Fill="White" Margin="0,0,0,5" />
                                <Ellipse Width="9" Height="9" Fill="White" />
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Numeric keypad button (PIN) -->
        <Style x:Key="KeypadButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
            <Setter Property="FontSize" Value="58" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="K" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2"
                                CornerRadius="24" MinWidth="150" MinHeight="120">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="K" Property="Background" Value="{StaticResource PrimaryTintBrush}" />
                                <Setter TargetName="K" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="K" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary (outline) pill button -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{StaticResource SurfaceBrush}" CornerRadius="16"
                                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2"
                                Padding="28,16" MinHeight="72">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource PrimaryTintBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="B" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ============================================================
         Portrait kiosk shell — 1080 x 1920 design canvas in a Uniform
         Viewbox so it fits any portrait touch panel at 9:16.
         ============================================================ -->
    <Grid ClipToBounds="True" Background="Black">
    <Viewbox Stretch="Uniform" StretchDirection="Both" RenderTransformOrigin="0.5,0.5">
        <!-- UI Scale (settings): an extra zoom on top of the fit. Applied as a
             RenderTransform (not LayoutTransform) so the Uniform Viewbox doesn't
             simply re-fit it away; >1 zooms in (clipped), <1 letterboxes. 1.0 = no change. -->
        <Viewbox.RenderTransform>
            <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
        </Viewbox.RenderTransform>
        <Grid x:Name="DesignCanvas" Width="1080" Height="1920" Background="Black">

            <!-- Background: branding image over gradient fallback -->
            <Rectangle Fill="{StaticResource BackgroundGradientBrush}" />
            <Image Source="{Binding BackgroundImage}" Stretch="UniformToFill"
                   Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />
            <Border Background="#33000000"
                    Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />

            <!-- ===================== BROWSE ===================== -->
            <Grid Visibility="{Binding IsBrowseVisible, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="48,40,48,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{Binding LogoImage}" Stretch="Uniform" Height="84" Margin="0,0,22,0"
                               Visibility="{Binding HasLogo, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="Bold"
                                   FontSize="48" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock HorizontalAlignment="Right">
                            <Run Text="{Binding BookCount, Mode=OneWay}" FontFamily="{StaticResource MonoFontFamily}"
                                 FontWeight="Bold" FontSize="34" Foreground="White" />
                            <Run Text=" เล่ม" FontSize="28" Foreground="#CCFFFFFF" />
                        </TextBlock>
                        <TextBlock HorizontalAlignment="Right" FontSize="24" Foreground="#B3FFFFFF" Margin="0,4,0,0">
                            <Run Text="อัปเดต " /><Run Text="{Binding LastUpdated, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Settings (opens PIN gate) -->
                    <Button Grid.Column="2" Style="{StaticResource GearButtonStyle}"
                            AutomationProperties.Name="ตั้งค่า" VerticalAlignment="Center"
                            Command="{Binding OpenSettingsCommand}" />
                </Grid>

                <!-- Body panel -->
                <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="44,44,0,0">
                    <Grid Margin="44,40,44,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Search -->
                        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2"
                                CornerRadius="26" Height="116" Padding="28,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Width="44" Height="44" Margin="0,0,18,0" VerticalAlignment="Center">
                                    <Ellipse Width="30" Height="30" Stroke="{StaticResource MutedBrush}" StrokeThickness="3"
                                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="1" />
                                    <Line X1="27" Y1="27" X2="42" Y2="42" Stroke="{StaticResource MutedBrush}"
                                          StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Grid>

                                <Grid Grid.Column="1">
                                    <TextBlock Text="ค้นหาชื่อหนังสือ เลขทะเบียน หมวดหมู่ หรือสำนักพิมพ์"
                                               FontSize="36" Foreground="{StaticResource MutedBrush}"
                                               VerticalAlignment="Center" IsHitTestVisible="False"
                                               Visibility="{Binding HasQuery, Converter={StaticResource InvBoolToVis}}" />
                                    <TextBox Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="36" Foreground="{StaticResource TextBrush}"
                                             FontFamily="{StaticResource AppFontFamily}"
                                             Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"
                                             CaretBrush="{StaticResource PrimaryBrush}" />
                                </Grid>

                                <Button Grid.Column="2" Command="{Binding ClearQueryCommand}" Width="56" Height="56"
                                        Cursor="Hand" VerticalAlignment="Center"
                                        Visibility="{Binding HasQuery, Converter={StaticResource BoolToVis}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#F1F5FA" CornerRadius="28">
                                                <Grid Width="28" Height="28">
                                                    <Line X1="6" Y1="6" X2="22" Y2="22" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="22" Y1="6" X2="6" Y2="22" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Category chips (command-driven, deterministic selection) -->
                        <ItemsControl Grid.Row="1" Margin="0,26,0,0" ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,16,16" Cursor="Hand"
                                            Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Name}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Chip" CornerRadius="999"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="2"
                                                        Padding="30,16" MinHeight="64">
                                                    <TextBlock x:Name="ChipText" Text="{Binding Name}" FontWeight="SemiBold"
                                                               FontSize="32" Foreground="{StaticResource PrimaryBrush}"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter TargetName="Chip" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                                        <Setter TargetName="Chip" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                        <Setter TargetName="ChipText" Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Result count -->
                        <TextBlock Grid.Row="2" Margin="2,4,0,18">
                            <Run Text="พบ " FontSize="30" Foreground="{StaticResource TextSecondBrush}" />
                            <Run Text="{Binding FilteredCount, Mode=OneWay}" FontFamily="{StaticResource MonoFontFamily}"
                                 FontWeight="Bold" FontSize="30" Foreground="{StaticResource TextBrush}" />
                            <Run Text=" เล่ม" FontSize="30" Foreground="{StaticResource TextSecondBrush}" />
                        </TextBlock>

                        <!-- Grid -->
                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding IsEmpty, Converter={StaticResource InvBoolToVis}}">
                            <ItemsControl ItemsSource="{Binding FilteredBooks}" Margin="-12,0,-12,24">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource CardButtonStyle}"
                                                Command="{Binding DataContext.SelectBookCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty state -->
                        <StackPanel Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                            <Border Width="180" Height="180" CornerRadius="90" Background="#E7EDF5"
                                    HorizontalAlignment="Center">
                                <Grid Width="80" Height="80">
                                    <Ellipse Width="56" Height="56" Stroke="#9DB0C8" StrokeThickness="5"
                                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2" />
                                    <Line X1="52" Y1="52" X2="76" Y2="76" Stroke="#9DB0C8" StrokeThickness="5"
                                          StrokeStartLineCap="Round" />
                                </Grid>
                            </Border>
                            <TextBlock Text="ไม่พบหนังสือที่ค้นหา" FontWeight="Bold" FontSize="44"
                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,30,0,0" />
                            <TextBlock Text="ลองเปลี่ยนคำค้น หรือเลือกหมวดอื่น" FontSize="30"
                                       Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,12,0,0" />
                            <Button Content="ดูหนังสือทั้งหมด" Command="{Binding ResetBrowseCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Margin="0,34,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===================== INITIAL LOADING ===================== -->
            <Grid Visibility="{Binding IsInitialLoading, Converter={StaticResource BoolToVis}}">
                <Border Background="#CC0F1A33" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="กำลังโหลดข้อมูลห้องสมุด…" Foreground="White" FontWeight="SemiBold"
                               FontSize="44" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BaseUrl}" Foreground="#B3FFFFFF" FontSize="28"
                               FontFamily="{StaticResource MonoFontFamily}" HorizontalAlignment="Center" Margin="0,16,0,0" />
                </StackPanel>
            </Grid>

            <!-- ===================== ERROR (unreachable) ===================== -->
            <Grid Visibility="{Binding IsErrorVisible, Converter={StaticResource BoolToVis}}">
                <Border Background="#E60F1A33" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="820">
                    <Border Width="200" Height="200" CornerRadius="100" Background="#1FFFFFFF"
                            BorderBrush="#33FFFFFF" BorderThickness="1" HorizontalAlignment="Center">
                        <TextBlock Text="!" Foreground="White" FontWeight="Bold" FontSize="120"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="เชื่อมต่อเซิร์ฟเวอร์ไม่ได้" Foreground="White" FontWeight="Bold"
                               FontSize="52" HorizontalAlignment="Center" Margin="0,40,0,0" />
                    <TextBlock Text="ระบบจะลองเชื่อมต่อใหม่อัตโนมัติ หรือกดปุ่มด้านล่างเพื่อลองอีกครั้ง"
                               Foreground="#D9FFFFFF" FontSize="30" TextAlignment="Center" TextWrapping="Wrap"
                               HorizontalAlignment="Center" Margin="0,16,0,0" />
                    <TextBlock Text="{Binding BaseUrl}" Foreground="#99FFFFFF" FontSize="26"
                               FontFamily="{StaticResource MonoFontFamily}" HorizontalAlignment="Center" Margin="0,18,0,0" />
                    <Button Content="ลองอีกครั้ง" Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Margin="0,40,0,0" />
                </StackPanel>
                <!-- always reachable so an admin can fix the URL when stuck offline -->
                <Button Style="{StaticResource GearButtonStyle}" AutomationProperties.Name="ตั้งค่า"
                        Command="{Binding OpenSettingsCommand}"
                        VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,48,48,0" />
            </Grid>

            <!-- ===================== UNLICENSED ===================== -->
            <Grid Visibility="{Binding IsUnlicensedVisible, Converter={StaticResource BoolToVis}}">
                <Border Background="#E60F1A33" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="820">
                    <TextBlock Text="เซิร์ฟเวอร์ยังไม่ได้เปิดใช้งานลิขสิทธิ์" Foreground="White" FontWeight="Bold"
                               FontSize="46" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#D9FFFFFF" FontSize="30"
                               TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,18,0,0" />
                    <Button Content="ลองอีกครั้ง" Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Margin="0,40,0,0" />
                </StackPanel>
                <Button Style="{StaticResource GearButtonStyle}" AutomationProperties.Name="ตั้งค่า"
                        Command="{Binding OpenSettingsCommand}"
                        VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,48,48,0" />
            </Grid>

            <!-- ===================== DETAIL MODAL ===================== -->
            <Grid Visibility="{Binding IsDetailOpen, Converter={StaticResource BoolToVis}}">
                <Border Background="#B3091122" />
                <Border Width="880" MaxHeight="1640" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{StaticResource SurfaceBrush}" CornerRadius="36"
                        DataContext="{Binding SelectedBook}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Cover -->
                        <Border Grid.Row="0" Height="720" CornerRadius="36,36,0,0" ClipToBounds="True"
                                Background="{Binding PlaceholderBrush}">
                            <Grid>
                                <Image Source="{Binding Cover}" Stretch="UniformToFill"
                                       Visibility="{Binding HasCover, Converter={StaticResource BoolToVis}}" />
                                <Border VerticalAlignment="Bottom" Height="240">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#00000000" Offset="0" />
                                            <GradientStop Color="#D9000000" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <StackPanel VerticalAlignment="Bottom" Margin="44,0,44,34">
                                    <Border HorizontalAlignment="Left" CornerRadius="999" Background="#33FFFFFF" Padding="18,8" Margin="0,0,0,16">
                                        <TextBlock Text="{Binding Category}" Foreground="White" FontWeight="SemiBold" FontSize="26" />
                                    </Border>
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold"
                                               FontSize="52" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Info -->
                        <StackPanel Grid.Row="1" Margin="44,32,44,40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="เลขทะเบียน" FontSize="26" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding RegNo}" FontFamily="{StaticResource MonoFontFamily}"
                                               FontWeight="Bold" FontSize="38" Foreground="{StaticResource TextBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Visibility="{Binding HasPublisher, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="สำนักพิมพ์" FontSize="26" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding Publisher}" FontWeight="SemiBold" FontSize="34"
                                               Foreground="{StaticResource TextBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Border Margin="0,28,0,0" Background="{StaticResource PrimaryTintBrush}"
                                    BorderBrush="#D7E2F0" BorderThickness="1" CornerRadius="22" Padding="28,22"
                                    Visibility="{Binding HasShelf, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="72" Height="72" CornerRadius="18" Background="{StaticResource PrimaryBrush}" Margin="0,0,22,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Width="9" Height="34" CornerRadius="2" Background="White" Margin="2,0" />
                                            <Border Width="9" Height="34" CornerRadius="2" Background="#CCFFFFFF" Margin="2,0" />
                                            <Border Width="9" Height="34" CornerRadius="2" Background="White" Margin="2,0" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="ตำแหน่งหนังสือ · ชั้นวาง" FontSize="26" Foreground="#5577A8" />
                                        <TextBlock Text="{Binding Shelf}" FontWeight="Bold" FontSize="40"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,2,0,0" />

                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Button Content="ปิด" Margin="0,30,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding DataContext.CloseDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Close X -->
                <Button Width="84" Height="84" VerticalAlignment="Top" HorizontalAlignment="Right"
                        Margin="0,60,80,0" Cursor="Hand"
                        Command="{Binding CloseDetailCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#33FFFFFF" CornerRadius="42" BorderBrush="#4DFFFFFF" BorderThickness="1">
                                <Grid Width="34" Height="34">
                                    <Line X1="7" Y1="7" X2="27" Y2="27" Stroke="White" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Line X1="27" Y1="7" X2="7" Y2="27" Stroke="White" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ===================== ADMIN SETTINGS OVERLAY (Phase 5) ===================== -->
            <Grid DataContext="{Binding Settings}"
                  Visibility="{Binding IsOpen, Converter={StaticResource BoolToVis}}">
                <Border Background="#D90B1426" />

                <!-- PIN keypad (gate + change-PIN) -->
                <Border Width="780" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{StaticResource SurfaceBrush}" CornerRadius="40" Padding="56,48"
                        Visibility="{Binding ShowKeypad, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding Pad.Title}" FontWeight="Bold" FontSize="48"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding Pad.Subtitle}" FontSize="30"
                                   Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"
                                   Margin="0,10,0,0" TextAlignment="Center" />

                        <!-- entered digits, masked -->
                        <Border Background="{StaticResource PanelBrush}" CornerRadius="20" Height="96"
                                Margin="0,30,0,0">
                            <TextBlock Text="{Binding Pad.Mask}" FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="56" Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <!-- error / attempts -->
                        <TextBlock Text="{Binding Pad.ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                                   FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Margin="0,18,0,0" TextAlignment="Center" TextWrapping="Wrap"
                                   Visibility="{Binding Pad.HasError, Converter={StaticResource BoolToVis}}" />

                        <!-- keypad -->
                        <UniformGrid Columns="3" Margin="0,24,0,0">
                            <Button Content="1" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="1" />
                            <Button Content="2" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="2" />
                            <Button Content="3" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="3" />
                            <Button Content="4" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="4" />
                            <Button Content="5" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="5" />
                            <Button Content="6" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="6" />
                            <Button Content="7" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="7" />
                            <Button Content="8" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="8" />
                            <Button Content="9" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="9" />
                            <Button Content="ลบ" FontSize="34" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.BackspaceCommand}" />
                            <Button Content="0" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="0" />
                            <Button Content="ตกลง" FontSize="34" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.SubmitCommand}" />
                        </UniformGrid>

                        <!-- close (gate) / cancel (change-PIN) -->
                        <Button Content="ปิด" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CloseCommand}" Margin="0,28,0,0"
                                Visibility="{Binding ShowGate, Converter={StaticResource BoolToVis}}" />
                        <Button Content="ยกเลิก" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CancelChangePinCommand}" Margin="0,28,0,0"
                                Visibility="{Binding ShowChangePin, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>

                <!-- lock screen -->
                <Border Width="780" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{StaticResource SurfaceBrush}" CornerRadius="40" Padding="56,56"
                        Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Border Width="170" Height="170" CornerRadius="85" Background="#FBE9E7"
                                HorizontalAlignment="Center">
                            <Grid Width="78" Height="86" VerticalAlignment="Center">
                                <Border Width="78" Height="56" VerticalAlignment="Bottom" CornerRadius="14"
                                        Background="{StaticResource ErrorBrush}" />
                                <Border Width="46" Height="46" VerticalAlignment="Top" HorizontalAlignment="Center"
                                        BorderBrush="{StaticResource ErrorBrush}" BorderThickness="10,10,10,0"
                                        CornerRadius="23,23,0,0" />
                            </Grid>
                        </Border>
                        <TextBlock Text="PIN ถูกล็อก" FontWeight="Bold" FontSize="50"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,30,0,0" />
                        <TextBlock Text="{Binding LockMessage}" FontSize="32" Foreground="{StaticResource TextSecondBrush}"
                                   HorizontalAlignment="Center" Margin="0,16,0,0" TextAlignment="Center" TextWrapping="Wrap" />
                        <Button Content="ปิด" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CloseCommand}" Margin="0,36,0,0" />
                    </StackPanel>
                </Border>

                <!-- settings panel -->
                <Border Width="920" MaxHeight="1740" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{StaticResource PanelBrush}" CornerRadius="40"
                        Visibility="{Binding ShowPanel, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- panel header -->
                        <Grid Grid.Row="0" Margin="48,40,40,8">
                            <TextBlock Text="ตั้งค่า" FontWeight="Bold" FontSize="52"
                                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                            <Button Width="76" Height="76" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Cursor="Hand" Command="{Binding CloseCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="38"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2">
                                            <Grid Width="30" Height="30">
                                                <Line X1="6" Y1="6" X2="24" Y2="24" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                <Line X1="24" Y1="6" X2="6" Y2="24" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled" Margin="0,8,0,0">
                            <StackPanel Margin="44,8,44,44">

                                <!-- การเชื่อมต่อ -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="28" Padding="36,32" Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock Text="การเชื่อมต่อ" FontWeight="Bold" FontSize="36"
                                                   Foreground="{StaticResource PrimaryBrush}" />
                                        <TextBlock Text="ที่อยู่เซิร์ฟเวอร์ (Base URL)" FontSize="28"
                                                   Foreground="{StaticResource MutedBrush}" Margin="0,22,0,10" />
                                        <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="2" CornerRadius="18" Padding="22,0" Height="92">
                                            <TextBox Text="{Binding BaseUrlInput, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="{StaticResource MonoFontFamily}" FontSize="32"
                                                     Foreground="{StaticResource TextBrush}" Background="Transparent"
                                                     BorderThickness="0" VerticalContentAlignment="Center"
                                                     CaretBrush="{StaticResource PrimaryBrush}" />
                                        </Border>
                                        <Grid Margin="0,22,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="บันทึก &amp; เชื่อมต่อ"
                                                    Style="{StaticResource PrimaryButtonStyle}" FontSize="32"
                                                    Command="{Binding SaveBaseUrlCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                                                    HorizontalAlignment="Left" />
                                            <Button Grid.Column="1" Content="ซิงก์ตอนนี้" Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding SyncNowCommand}" Margin="18,0,0,0" />
                                        </Grid>
                                        <TextBlock Text="{Binding ConnectionStatus}" FontSize="28"
                                                   Foreground="{StaticResource TextSecondBrush}" Margin="0,18,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <!-- การแสดงผล -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="28" Padding="36,32" Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock Text="การแสดงผล" FontWeight="Bold" FontSize="36"
                                                   Foreground="{StaticResource PrimaryBrush}" />

                                        <TextBlock Text="ชื่อระบบ (จากเซิร์ฟเวอร์)" FontSize="28"
                                                   Foreground="{StaticResource MutedBrush}" Margin="0,22,0,6" />
                                        <TextBlock Text="{Binding DisplayName}" FontSize="34" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" />

                                        <!-- logo -->
                                        <Grid Margin="0,28,0,0">
                                            <TextBlock Text="โลโก้ (เครื่องนี้)" FontSize="30" Foreground="{StaticResource TextBrush}"
                                                       VerticalAlignment="Center" />
                                            <Button HorizontalAlignment="Right" Content="ลบโลโก้" Style="{StaticResource SecondaryButtonStyle}"
                                                    FontSize="28" Command="{Binding ToggleLogoCommand}" IsEnabled="{Binding LogoAvailable}"
                                                    Visibility="{Binding HideLogo, Converter={StaticResource InvBoolToVis}}" />
                                            <Button HorizontalAlignment="Right" Content="แสดงโลโก้" Style="{StaticResource SecondaryButtonStyle}"
                                                    FontSize="28" Command="{Binding ToggleLogoCommand}"
                                                    Visibility="{Binding HideLogo, Converter={StaticResource BoolToVis}}" />
                                        </Grid>

                                        <!-- background -->
                                        <Grid Margin="0,18,0,0">
                                            <TextBlock Text="ภาพพื้นหลัง (เครื่องนี้)" FontSize="30" Foreground="{StaticResource TextBrush}"
                                                       VerticalAlignment="Center" />
                                            <Button HorizontalAlignment="Right" Content="ลบพื้นหลัง" Style="{StaticResource SecondaryButtonStyle}"
                                                    FontSize="28" Command="{Binding ToggleBackgroundCommand}" IsEnabled="{Binding BackgroundAvailable}"
                                                    Visibility="{Binding HideBackground, Converter={StaticResource InvBoolToVis}}" />
                                            <Button HorizontalAlignment="Right" Content="แสดงพื้นหลัง" Style="{StaticResource SecondaryButtonStyle}"
                                                    FontSize="28" Command="{Binding ToggleBackgroundCommand}"
                                                    Visibility="{Binding HideBackground, Converter={StaticResource BoolToVis}}" />
                                        </Grid>

                                        <!-- UI scale -->
                                        <Grid Margin="0,30,0,0">
                                            <TextBlock Text="ขนาดการแสดงผล" FontSize="30" Foreground="{StaticResource TextBrush}" />
                                            <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource MonoFontFamily}"
                                                       FontSize="30" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                                                       Text="{Binding UiScalePercent, StringFormat={}{0:0}%}" />
                                        </Grid>
                                        <Slider Minimum="80" Maximum="120" Value="{Binding UiScalePercent}"
                                                TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,12,0,0" Height="48" />

                                        <!-- display mode -->
                                        <TextBlock Text="โหมดการแสดงผล" FontSize="30" Foreground="{StaticResource TextBrush}" Margin="0,24,0,12" />
                                        <UniformGrid Columns="2">
                                            <Button Content="เต็มจอ (Kiosk)" Command="{Binding SetFullscreenCommand}" Cursor="Hand" Margin="0,0,9,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="M" Background="{StaticResource SurfaceBrush}" CornerRadius="18"
                                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" MinHeight="80">
                                                            <TextBlock x:Name="T" Text="{TemplateBinding Content}" FontSize="30" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsFullscreen}" Value="True">
                                                                <Setter TargetName="M" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter TargetName="M" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter TargetName="T" Property="Foreground" Value="White" />
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="หน้าต่าง (ทดสอบ)" Command="{Binding SetWindowedCommand}" Cursor="Hand" Margin="9,0,0,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="M" Background="{StaticResource SurfaceBrush}" CornerRadius="18"
                                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" MinHeight="80">
                                                            <TextBlock x:Name="T" Text="{TemplateBinding Content}" FontSize="30" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsFullscreen}" Value="False">
                                                                <Setter TargetName="M" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter TargetName="M" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter TargetName="T" Property="Foreground" Value="White" />
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <!-- ความปลอดภัย -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="28" Padding="36,32" Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock Text="ความปลอดภัย" FontWeight="Bold" FontSize="36"
                                                   Foreground="{StaticResource PrimaryBrush}" />
                                        <Button Content="เปลี่ยน PIN" Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding StartChangePinCommand}" HorizontalAlignment="Left" Margin="0,22,0,0" />
                                        <TextBlock Text="{Binding ChangePinResult}" FontSize="28" FontWeight="SemiBold"
                                                   Foreground="{StaticResource SuccessBrush}" Margin="0,16,0,0"
                                                   Visibility="{Binding ChangePinResult, Converter={StaticResource StrToVis}}" />
                                    </StackPanel>
                                </Border>

                                <!-- เกี่ยวกับ -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="28" Padding="36,32">
                                    <StackPanel>
                                        <TextBlock Text="เกี่ยวกับ" FontWeight="Bold" FontSize="36"
                                                   Foreground="{StaticResource PrimaryBrush}" />
                                        <TextBlock Text="{Binding AboutVersion}" FontSize="28"
                                                   Foreground="{StaticResource TextSecondBrush}" Margin="0,16,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Viewbox>
    </Grid>
</Window>
