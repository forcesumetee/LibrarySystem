<Window x:Class="LibraryKiosk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LibraryKiosk.ViewModels"
        xmlns:conv="clr-namespace:LibraryKiosk.Utils"
        Title="Library Kiosk"
        Height="960" Width="540"
        MinHeight="480" MinWidth="270"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        FontFamily="{StaticResource AppFontFamily}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis" />

        <!-- Book card button -->
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardRoot" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="20" SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="360" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Cover -->
                                <Border Grid.Row="0" CornerRadius="20,20,0,0" ClipToBounds="True"
                                        Background="{Binding PlaceholderBrush}">
                                    <Grid>
                                        <Image Source="{Binding Cover}" Stretch="UniformToFill"
                                               Visibility="{Binding HasCover, Converter={StaticResource BoolToVis}}" />
                                        <!-- bottom scrim for title legibility -->
                                        <Border VerticalAlignment="Bottom" Height="170">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#00000000" Offset="0" />
                                                    <GradientStop Color="#CC000000" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel VerticalAlignment="Bottom" Margin="20,0,20,16">
                                            <TextBlock Text="{Binding Title}" Foreground="White"
                                                       FontWeight="Bold" FontSize="30" TextWrapping="Wrap"
                                                       MaxHeight="118" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Publisher}" Foreground="#D8FFFFFF"
                                                       FontWeight="Regular" FontSize="22" Margin="0,4,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding HasPublisher, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Meta -->
                                <StackPanel Grid.Row="1" Margin="18,14,18,16">
                                    <TextBlock Text="{Binding RegNo}" FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="24" Foreground="{StaticResource MutedBrush}" />
                                    <Grid Margin="0,12,0,0">
                                        <Border HorizontalAlignment="Left" CornerRadius="999"
                                                Background="{StaticResource PrimaryTintBrush}" Padding="14,7">
                                            <TextBlock Text="{Binding Category}" FontWeight="SemiBold" FontSize="22"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="180" />
                                        </Border>
                                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontFamily="{StaticResource MonoFontFamily}" FontSize="24"
                                                   Foreground="{StaticResource TextSecondBrush}"
                                                   Text="{Binding Shelf}"
                                                   Visibility="{Binding HasShelf, Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardRoot" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="CardRoot" Property="BorderThickness" Value="3" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary pill button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="40" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{StaticResource PrimaryBrush}" CornerRadius="20"
                                Padding="56,22" MinHeight="88">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ============================================================
         Portrait kiosk shell — 1080 x 1920 design canvas in a Uniform
         Viewbox so it fits any portrait touch panel at 9:16.
         ============================================================ -->
    <Viewbox Stretch="Uniform" StretchDirection="Both">
        <Grid x:Name="DesignCanvas" Width="1080" Height="1920" Background="Black">

            <!-- Background: branding image over gradient fallback -->
            <Rectangle Fill="{StaticResource BackgroundGradientBrush}" />
            <Image Source="{Binding BackgroundImage}" Stretch="UniformToFill"
                   Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />
            <Border Background="#33000000"
                    Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />

            <!-- ===================== BROWSE ===================== -->
            <Grid Visibility="{Binding IsBrowseVisible, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="48,40,48,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{Binding LogoImage}" Stretch="Uniform" Height="84" Margin="0,0,22,0"
                               Visibility="{Binding HasLogo, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="Bold"
                                   FontSize="48" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock HorizontalAlignment="Right">
                            <Run Text="{Binding BookCount, Mode=OneWay}" FontFamily="{StaticResource MonoFontFamily}"
                                 FontWeight="Bold" FontSize="34" Foreground="White" />
                            <Run Text=" เล่ม" FontSize="28" Foreground="#CCFFFFFF" />
                        </TextBlock>
                        <TextBlock HorizontalAlignment="Right" FontSize="24" Foreground="#B3FFFFFF" Margin="0,4,0,0">
                            <Run Text="อัปเดต " /><Run Text="{Binding LastUpdated, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Settings (PIN gate in Phase 5) -->
                    <Button Grid.Column="2" Width="88" Height="88" Cursor="Hand"
                            Command="{Binding OpenSettingsCommand}" VerticalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#26FFFFFF" CornerRadius="44" BorderBrush="#40FFFFFF" BorderThickness="1">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="9" Height="9" Fill="White" Margin="0,0,0,5" />
                                        <Ellipse Width="9" Height="9" Fill="White" Margin="0,0,0,5" />
                                        <Ellipse Width="9" Height="9" Fill="White" />
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Body panel -->
                <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="44,44,0,0">
                    <Grid Margin="44,40,44,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Search -->
                        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2"
                                CornerRadius="26" Height="116" Padding="28,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Width="44" Height="44" Margin="0,0,18,0" VerticalAlignment="Center">
                                    <Ellipse Width="30" Height="30" Stroke="{StaticResource MutedBrush}" StrokeThickness="3"
                                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="1" />
                                    <Line X1="27" Y1="27" X2="42" Y2="42" Stroke="{StaticResource MutedBrush}"
                                          StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Grid>

                                <Grid Grid.Column="1">
                                    <TextBlock Text="ค้นหาชื่อหนังสือ เลขทะเบียน หมวดหมู่ หรือสำนักพิมพ์"
                                               FontSize="36" Foreground="{StaticResource MutedBrush}"
                                               VerticalAlignment="Center" IsHitTestVisible="False"
                                               Visibility="{Binding HasQuery, Converter={StaticResource InvBoolToVis}}" />
                                    <TextBox Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="36" Foreground="{StaticResource TextBrush}"
                                             FontFamily="{StaticResource AppFontFamily}"
                                             Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"
                                             CaretBrush="{StaticResource PrimaryBrush}" />
                                </Grid>

                                <Button Grid.Column="2" Command="{Binding ClearQueryCommand}" Width="56" Height="56"
                                        Cursor="Hand" VerticalAlignment="Center"
                                        Visibility="{Binding HasQuery, Converter={StaticResource BoolToVis}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#F1F5FA" CornerRadius="28">
                                                <Grid Width="28" Height="28">
                                                    <Line X1="6" Y1="6" X2="22" Y2="22" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="22" Y1="6" X2="6" Y2="22" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Category chips (command-driven, deterministic selection) -->
                        <ItemsControl Grid.Row="1" Margin="0,26,0,0" ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,16,16" Cursor="Hand"
                                            Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Name}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Chip" CornerRadius="999"
                                                        Background="{StaticResource SurfaceBrush}"
                                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="2"
                                                        Padding="30,16" MinHeight="64">
                                                    <TextBlock x:Name="ChipText" Text="{Binding Name}" FontWeight="SemiBold"
                                                               FontSize="32" Foreground="{StaticResource PrimaryBrush}"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter TargetName="Chip" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                                        <Setter TargetName="Chip" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                        <Setter TargetName="ChipText" Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Result count -->
                        <TextBlock Grid.Row="2" Margin="2,4,0,18">
                            <Run Text="พบ " FontSize="30" Foreground="{StaticResource TextSecondBrush}" />
                            <Run Text="{Binding FilteredCount, Mode=OneWay}" FontFamily="{StaticResource MonoFontFamily}"
                                 FontWeight="Bold" FontSize="30" Foreground="{StaticResource TextBrush}" />
                            <Run Text=" เล่ม" FontSize="30" Foreground="{StaticResource TextSecondBrush}" />
                        </TextBlock>

                        <!-- Grid -->
                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding IsEmpty, Converter={StaticResource InvBoolToVis}}">
                            <ItemsControl ItemsSource="{Binding FilteredBooks}" Margin="-12,0,-12,24">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource CardButtonStyle}"
                                                Command="{Binding DataContext.SelectBookCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty state -->
                        <StackPanel Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                            <Border Width="180" Height="180" CornerRadius="90" Background="#E7EDF5"
                                    HorizontalAlignment="Center">
                                <Grid Width="80" Height="80">
                                    <Ellipse Width="56" Height="56" Stroke="#9DB0C8" StrokeThickness="5"
                                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2" />
                                    <Line X1="52" Y1="52" X2="76" Y2="76" Stroke="#9DB0C8" StrokeThickness="5"
                                          StrokeStartLineCap="Round" />
                                </Grid>
                            </Border>
                            <TextBlock Text="ไม่พบหนังสือที่ค้นหา" FontWeight="Bold" FontSize="44"
                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,30,0,0" />
                            <TextBlock Text="ลองเปลี่ยนคำค้น หรือเลือกหมวดอื่น" FontSize="30"
                                       Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,12,0,0" />
                            <Button Content="ดูหนังสือทั้งหมด" Command="{Binding ResetBrowseCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Margin="0,34,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===================== INITIAL LOADING ===================== -->
            <Grid Visibility="{Binding IsInitialLoading, Converter={StaticResource BoolToVis}}">
                <Border Background="#CC0F1A33" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="กำลังโหลดข้อมูลห้องสมุด…" Foreground="White" FontWeight="SemiBold"
                               FontSize="44" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding BaseUrl}" Foreground="#B3FFFFFF" FontSize="28"
                               FontFamily="{StaticResource MonoFontFamily}" HorizontalAlignment="Center" Margin="0,16,0,0" />
                </StackPanel>
            </Grid>

            <!-- ===================== ERROR (unreachable) ===================== -->
            <Grid Visibility="{Binding IsErrorVisible, Converter={StaticResource BoolToVis}}">
                <Border Background="#E60F1A33" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="820">
                    <Border Width="200" Height="200" CornerRadius="100" Background="#1FFFFFFF"
                            BorderBrush="#33FFFFFF" BorderThickness="1" HorizontalAlignment="Center">
                        <TextBlock Text="!" Foreground="White" FontWeight="Bold" FontSize="120"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="เชื่อมต่อเซิร์ฟเวอร์ไม่ได้" Foreground="White" FontWeight="Bold"
                               FontSize="52" HorizontalAlignment="Center" Margin="0,40,0,0" />
                    <TextBlock Text="ระบบจะลองเชื่อมต่อใหม่อัตโนมัติ หรือกดปุ่มด้านล่างเพื่อลองอีกครั้ง"
                               Foreground="#D9FFFFFF" FontSize="30" TextAlignment="Center" TextWrapping="Wrap"
                               HorizontalAlignment="Center" Margin="0,16,0,0" />
                    <TextBlock Text="{Binding BaseUrl}" Foreground="#99FFFFFF" FontSize="26"
                               FontFamily="{StaticResource MonoFontFamily}" HorizontalAlignment="Center" Margin="0,18,0,0" />
                    <Button Content="ลองอีกครั้ง" Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Margin="0,40,0,0" />
                </StackPanel>
            </Grid>

            <!-- ===================== UNLICENSED ===================== -->
            <Grid Visibility="{Binding IsUnlicensedVisible, Converter={StaticResource BoolToVis}}">
                <Border Background="#E60F1A33" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="820">
                    <TextBlock Text="เซิร์ฟเวอร์ยังไม่ได้เปิดใช้งานลิขสิทธิ์" Foreground="White" FontWeight="Bold"
                               FontSize="46" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#D9FFFFFF" FontSize="30"
                               TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,18,0,0" />
                    <Button Content="ลองอีกครั้ง" Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Margin="0,40,0,0" />
                </StackPanel>
            </Grid>

            <!-- ===================== DETAIL MODAL ===================== -->
            <Grid Visibility="{Binding IsDetailOpen, Converter={StaticResource BoolToVis}}">
                <Border Background="#B3091122" />
                <Border Width="880" MaxHeight="1640" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{StaticResource SurfaceBrush}" CornerRadius="36"
                        DataContext="{Binding SelectedBook}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Cover -->
                        <Border Grid.Row="0" Height="720" CornerRadius="36,36,0,0" ClipToBounds="True"
                                Background="{Binding PlaceholderBrush}">
                            <Grid>
                                <Image Source="{Binding Cover}" Stretch="UniformToFill"
                                       Visibility="{Binding HasCover, Converter={StaticResource BoolToVis}}" />
                                <Border VerticalAlignment="Bottom" Height="240">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#00000000" Offset="0" />
                                            <GradientStop Color="#D9000000" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <StackPanel VerticalAlignment="Bottom" Margin="44,0,44,34">
                                    <Border HorizontalAlignment="Left" CornerRadius="999" Background="#33FFFFFF" Padding="18,8" Margin="0,0,0,16">
                                        <TextBlock Text="{Binding Category}" Foreground="White" FontWeight="SemiBold" FontSize="26" />
                                    </Border>
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold"
                                               FontSize="52" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Info -->
                        <StackPanel Grid.Row="1" Margin="44,32,44,40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="เลขทะเบียน" FontSize="26" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding RegNo}" FontFamily="{StaticResource MonoFontFamily}"
                                               FontWeight="Bold" FontSize="38" Foreground="{StaticResource TextBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Visibility="{Binding HasPublisher, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="สำนักพิมพ์" FontSize="26" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding Publisher}" FontWeight="SemiBold" FontSize="34"
                                               Foreground="{StaticResource TextBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Border Margin="0,28,0,0" Background="{StaticResource PrimaryTintBrush}"
                                    BorderBrush="#D7E2F0" BorderThickness="1" CornerRadius="22" Padding="28,22"
                                    Visibility="{Binding HasShelf, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="72" Height="72" CornerRadius="18" Background="{StaticResource PrimaryBrush}" Margin="0,0,22,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Width="9" Height="34" CornerRadius="2" Background="White" Margin="2,0" />
                                            <Border Width="9" Height="34" CornerRadius="2" Background="#CCFFFFFF" Margin="2,0" />
                                            <Border Width="9" Height="34" CornerRadius="2" Background="White" Margin="2,0" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="ตำแหน่งหนังสือ · ชั้นวาง" FontSize="26" Foreground="#5577A8" />
                                        <TextBlock Text="{Binding Shelf}" FontWeight="Bold" FontSize="40"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,2,0,0" />

                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Button Content="ปิด" Margin="0,30,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding DataContext.CloseDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Close X -->
                <Button Width="84" Height="84" VerticalAlignment="Top" HorizontalAlignment="Right"
                        Margin="0,60,80,0" Cursor="Hand"
                        Command="{Binding CloseDetailCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#33FFFFFF" CornerRadius="42" BorderBrush="#4DFFFFFF" BorderThickness="1">
                                <Grid Width="34" Height="34">
                                    <Line X1="7" Y1="7" X2="27" Y2="27" Stroke="White" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Line X1="27" Y1="7" X2="7" Y2="27" Stroke="White" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Viewbox>
</Window>
