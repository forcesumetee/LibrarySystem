<Window x:Class="LibraryKiosk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LibraryKiosk.ViewModels"
        xmlns:conv="clr-namespace:LibraryKiosk.Utils"
        Title="LibraHub Search"
        Height="960" Width="540"
        MinHeight="480" MinWidth="270"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        FontFamily="{StaticResource AppFontFamily}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:InverseBooleanConverter x:Key="InvBool" />
        <conv:StringToVisibilityConverter x:Key="StrToVis" />

        <!-- Book card button -->
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardRoot" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="20" SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <!-- press feedback: GPU-friendly RenderTransform scale (no layout pass).
                                 Identity at rest so virtualized scrolling is unaffected. -->
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="320" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Header: cover image (with cover) OR category colour + book
                                     glyph (no cover). Title/publisher moved to the white body so
                                     the card reads as a clean book card, not a solid colour block. -->
                                <Border Grid.Row="0" CornerRadius="20,20,0,0" ClipToBounds="True"
                                        Background="{Binding PlaceholderBrush}">
                                    <Grid>
                                        <!-- no cover: faded book glyph centred on the category colour -->
                                        <Viewbox Width="96" Height="96" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Visibility="{Binding HasCover, Converter={StaticResource InvBoolToVis}}">
                                            <Path Fill="#80FFFFFF"
                                                  Data="M3,5 C3,4.5 5,4 8,4 C10,4 11.5,4.5 12,5 L12,18 C11.5,17.5 10,17 8,17 C5,17 3,17.5 3,18 Z M21,5 C21,4.5 19,4 16,4 C14,4 12.5,4.5 12,5 L12,18 C12.5,17.5 14,17 16,17 C19,17 21,17.5 21,18 Z" />
                                        </Viewbox>
                                        <!-- cover present: whole cover, no crop (chip fills any margin).
                                             Fades in only when a genuinely new BitmapSource arrives: the
                                             VM reuses the cached instance on re-sync with an unchanged sha,
                                             so Cover doesn't raise PropertyChanged and TargetUpdated stays
                                             silent — no fade loop on re-sync. -->
                                        <Image Stretch="Uniform"
                                               Source="{Binding Cover, NotifyOnTargetUpdated=True}"
                                               Visibility="{Binding HasCover, Converter={StaticResource BoolToVis}}">
                                            <Image.Triggers>
                                                <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18">
                                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Image.Triggers>
                                        </Image>
                                    </Grid>
                                </Border>

                                <!-- White body: title, publisher, reg-no, category badge + shelf -->
                                <StackPanel Grid.Row="1" Margin="20,16,20,18">
                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextBrush}"
                                               FontWeight="Bold" FontSize="28" TextWrapping="Wrap"
                                               MaxHeight="76" TextTrimming="CharacterEllipsis" LineHeight="34" />
                                    <TextBlock Text="{Binding Publisher}" Foreground="{StaticResource TextSecondBrush}"
                                               FontSize="22" Margin="0,6,0,0" TextTrimming="CharacterEllipsis"
                                               Visibility="{Binding HasPublisher, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="{Binding RegNo}" FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="22" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0" />
                                    <Grid Margin="0,14,0,0">
                                        <!-- category badge: tinted pill in the category colour -->
                                        <Grid HorizontalAlignment="Left" MaxWidth="190">
                                            <Border CornerRadius="16" Background="{Binding PlaceholderBrush}" Opacity="0.16" />
                                            <TextBlock Text="{Binding Category}" Foreground="{Binding PlaceholderBrush}"
                                                       FontWeight="SemiBold" FontSize="21" Margin="16,7"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                        <!-- shelf: location pin + value -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Visibility="{Binding HasShelf, Converter={StaticResource BoolToVis}}">
                                            <Viewbox Width="26" Height="26" Margin="0,0,5,0">
                                                <Path Fill="{StaticResource MutedBrush}"
                                                      Data="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z" />
                                            </Viewbox>
                                            <TextBlock Text="{Binding Shelf}" FontFamily="{StaticResource MonoFontFamily}"
                                                       FontSize="22" Foreground="{StaticResource TextSecondBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardRoot" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Setter TargetName="CardRoot" Property="BorderThickness" Value="3" />
                                <!-- finger-down: quick shrink so the touch reads as registered -->
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                                                             To="0.96" Duration="0:0:0.09">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                                                             To="0.96" Duration="0:0:0.09">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <!-- release: spring back to 1.0 with a gentle overshoot -->
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleX"
                                                             To="1" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardScale" Storyboard.TargetProperty="ScaleY"
                                                             To="1" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary pill button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="40" />
            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{StaticResource PrimaryBrush}" CornerRadius="20"
                                Padding="56,22" MinHeight="88">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Theme-colour preset swatch (settings) — colour set per-button via Background. -->
        <Style x:Key="ThemeSwatchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="92" />
            <Setter Property="Height" Value="64" />
            <Setter Property="Margin" Value="0,0,16,16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="14"
                                BorderBrush="#22000000" BorderThickness="1" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Settings gear (three dots) — reused in header + stuck-state overlays -->
        <Style x:Key="GearButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="88" />
            <Setter Property="Height" Value="88" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#26FFFFFF" CornerRadius="44" BorderBrush="#40FFFFFF" BorderThickness="1">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Width="9" Height="9" Fill="White" Margin="0,0,0,5" />
                                <Ellipse Width="9" Height="9" Fill="White" Margin="0,0,0,5" />
                                <Ellipse Width="9" Height="9" Fill="White" />
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Numeric keypad button (PIN) -->
        <Style x:Key="KeypadButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
            <Setter Property="FontSize" Value="58" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="K" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2"
                                CornerRadius="24" MinWidth="150" MinHeight="120"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="KeyScale" ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="K" Property="Background" Value="{StaticResource PrimaryTintBrush}" />
                                <Setter TargetName="K" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KeyScale" Storyboard.TargetProperty="ScaleX" To="0.94" Duration="0:0:0.08">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="KeyScale" Storyboard.TargetProperty="ScaleY" To="0.94" Duration="0:0:0.08">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="KeyScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="KeyScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="K" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary (outline) pill button -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{StaticResource SurfaceBrush}" CornerRadius="16"
                                BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="2"
                                Padding="28,16" MinHeight="72">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource PrimaryTintBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="B" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Fade + slide-up for settings/PIN panels. Keyed on each panel's OWN Visibility
             (not Settings.IsOpen): gate->panel transitions happen while IsOpen is already
             true, so an IsOpen-keyed trigger would skip them and the panel would pop in.
             Each panel supplies its own inline TranslateTransform. View-only. -->
        <!-- Per-panel fade+slide, each keyed on its OWN visibility flag (DataContext = Settings).
             Keying on the panel's own flag (not IsOpen) is what makes the gate->settings-panel
             transition animate too — that happens while IsOpen is already true. Bind to a
             DataContext bool (proven pattern); a RelativeSource Self Visibility binding throws
             on style-apply. Each panel supplies its own inline TranslateTransform. View-only. -->
        <Storyboard x:Key="OverlayPanelEnterAnim">
            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Y" From="48" To="0" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Style x:Key="OverlayKeypadSlideStyle" TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowKeypad}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource OverlayPanelEnterAnim}" />
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="OverlayLockSlideStyle" TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLocked}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource OverlayPanelEnterAnim}" />
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="OverlayPanelSlideStyle" TargetType="Border">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowPanel}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard Storyboard="{StaticResource OverlayPanelEnterAnim}" />
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Category chip button visual (shared by the portrait + landscape browse).
             Theme-reactive via DynamicResource (instant swap, no colour fade) so changing the
             primary colour at runtime recolours selected/unselected chips immediately. -->
        <ControlTemplate x:Key="ChipButtonTemplate" TargetType="Button">
            <Border x:Name="Chip" CornerRadius="16" BorderThickness="2"
                    Padding="30,16" MinHeight="64"
                    Background="Transparent" BorderBrush="{DynamicResource BorderBrush}">
                <TextBlock x:Name="ChipText" Text="{Binding Name}" FontWeight="SemiBold"
                           FontSize="32" VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryBrush}" />
            </Border>
            <ControlTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="Chip" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                    <Setter TargetName="Chip" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                    <Setter TargetName="ChipText" Property="Foreground" Value="{DynamicResource OnPrimaryBrush}" />
                </DataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Welcome-screen category chip (white translucent pill) — shared portrait + landscape. -->
        <ControlTemplate x:Key="WelcomeChipTemplate" TargetType="Button">
            <Border CornerRadius="16" Background="#26FFFFFF"
                    BorderBrush="#59FFFFFF" BorderThickness="2" Padding="34,18">
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="34"
                           Foreground="White" VerticalAlignment="Center" />
            </Border>
        </ControlTemplate>
    </Window.Resources>

    <!-- ============================================================
         Portrait kiosk shell — 1080 x 1920 design canvas in a Uniform
         Viewbox so it fits any portrait touch panel at 9:16.
         ============================================================ -->
    <Grid ClipToBounds="True" Background="Black">
    <Viewbox Stretch="Uniform" StretchDirection="Both" RenderTransformOrigin="0.5,0.5">
        <!-- UI Scale (settings): an extra zoom on top of the fit. Applied as a
             RenderTransform (not LayoutTransform) so the Uniform Viewbox doesn't
             simply re-fit it away; >1 zooms in (clipped), <1 letterboxes. 1.0 = no change. -->
        <Viewbox.RenderTransform>
            <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}" />
        </Viewbox.RenderTransform>
        <Grid x:Name="DesignCanvas" Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" Background="Black">

            <!-- ============================================================
                 PORTRAIT ROOT — the existing layout, wrapped unchanged. Shown
                 when !IsLandscape. Landscape gets its own parallel root below.
                 ============================================================ -->
            <Grid x:Name="PortraitRoot" Visibility="{Binding IsLandscape, Converter={StaticResource InvBoolToVis}}">

            <!-- Background: branding image over gradient fallback -->
            <Rectangle Fill="{DynamicResource BackgroundGradientBrush}" />
            <Image Source="{Binding BackgroundImage}" Stretch="UniformToFill"
                   Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />
            <Border Background="#33000000"
                    Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />

            <!-- ===================== BROWSE ===================== -->
            <Grid Visibility="{Binding IsBrowseVisible, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="48,40,48,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="{Binding LogoImage}" Stretch="Uniform" Height="84" Margin="0,0,22,0"
                               Visibility="{Binding HasLogo, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="Bold"
                                   FontSize="48" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock HorizontalAlignment="Right">
                            <Run Text="{Binding BookCount, Mode=OneWay}" FontFamily="{StaticResource MonoFontFamily}"
                                 FontWeight="Bold" FontSize="34" Foreground="White" />
                            <Run Text=" เล่ม" FontSize="28" Foreground="#CCFFFFFF" />
                        </TextBlock>
                        <TextBlock HorizontalAlignment="Right" FontSize="24" Foreground="#B3FFFFFF" Margin="0,4,0,0">
                            <Run Text="อัปเดต " /><Run Text="{Binding LastUpdated, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Settings (opens PIN gate) -->
                    <Button Grid.Column="2" Style="{StaticResource GearButtonStyle}"
                            AutomationProperties.Name="ตั้งค่า" VerticalAlignment="Center"
                            Command="{Binding OpenSettingsCommand}" />
                </Grid>

                <!-- Body panel. Fill is its own brush so the opacity slider fades only the
                     panel surface (branding shows through) — the search/chips/cards on top
                     keep their own opaque brushes and never fade with it. -->
                <Border Grid.Row="1" CornerRadius="44,44,0,0">
                    <Border.Background>
                        <SolidColorBrush Color="{StaticResource PanelColor}" Opacity="{Binding BackgroundOpacity}" />
                    </Border.Background>
                    <Grid Margin="44,40,44,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Search -->
                        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2"
                                CornerRadius="26" Height="116" Padding="28,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Width="44" Height="44" Margin="0,0,18,0" VerticalAlignment="Center">
                                    <Ellipse Width="30" Height="30" Stroke="{StaticResource MutedBrush}" StrokeThickness="3"
                                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="1" />
                                    <Line X1="27" Y1="27" X2="42" Y2="42" Stroke="{StaticResource MutedBrush}"
                                          StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Grid>

                                <Grid Grid.Column="1">
                                    <TextBlock Text="ค้นหาชื่อหนังสือ เลขทะเบียน หมวดหมู่ หรือสำนักพิมพ์"
                                               FontSize="36" Foreground="{StaticResource MutedBrush}"
                                               VerticalAlignment="Center" IsHitTestVisible="False"
                                               Visibility="{Binding HasQuery, Converter={StaticResource InvBoolToVis}}" />
                                    <TextBox x:Name="SearchBox" Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="36" Foreground="{StaticResource TextBrush}"
                                             FontFamily="{StaticResource AppFontFamily}" ContextMenu="{x:Null}"
                                             Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"
                                             CaretBrush="{StaticResource PrimaryBrush}" />
                                </Grid>

                                <Button Grid.Column="2" Command="{Binding ClearQueryCommand}" Width="56" Height="56"
                                        Cursor="Hand" VerticalAlignment="Center"
                                        Visibility="{Binding HasQuery, Converter={StaticResource BoolToVis}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#F1F5FA" CornerRadius="28">
                                                <Grid Width="28" Height="28">
                                                    <Line X1="6" Y1="6" X2="22" Y2="22" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <Line X1="22" Y1="6" X2="6" Y2="22" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Category chips (command-driven, deterministic selection) -->
                        <ItemsControl Grid.Row="1" Margin="0,26,0,0" ItemsSource="{Binding Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,16,16" Cursor="Hand"
                                            Template="{StaticResource ChipButtonTemplate}"
                                            Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Name}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Result count -->
                        <TextBlock Grid.Row="2" Margin="2,4,0,18">
                            <Run Text="พบ " FontSize="30" Foreground="{StaticResource TextSecondBrush}" />
                            <Run Text="{Binding FilteredCount, Mode=OneWay}" FontFamily="{StaticResource MonoFontFamily}"
                                 FontWeight="Bold" FontSize="30" Foreground="{StaticResource TextBrush}" />
                            <Run Text=" เล่ม" FontSize="30" Foreground="{StaticResource TextSecondBrush}" />
                        </TextBlock>

                        <!-- Grid: rows of 3 inside a VirtualizingStackPanel so thousands of
                             books stay smooth (only visible rows are realised). -->
                        <ItemsControl x:Name="CardsHost" Grid.Row="3"
                                      ItemsSource="{Binding BookRows}" Margin="-12,0,-12,24"
                                      Visibility="{Binding IsEmpty, Converter={StaticResource InvBoolToVis}}"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                      VirtualizingPanel.ScrollUnit="Pixel"
                                      ScrollViewer.CanContentScroll="True"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer CanContentScroll="True" Focusable="False"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding Cards}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="3" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource CardButtonStyle}"
                                                        Command="{Binding DataContext.SelectBookCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty state -->
                        <StackPanel Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                            <Border Width="180" Height="180" CornerRadius="90" Background="{DynamicResource PrimaryTintBrush}"
                                    HorizontalAlignment="Center">
                                <Grid Width="80" Height="80">
                                    <Ellipse Width="56" Height="56" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="5"
                                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2" />
                                    <Line X1="52" Y1="52" X2="76" Y2="76" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="5"
                                          StrokeStartLineCap="Round" />
                                </Grid>
                            </Border>
                            <TextBlock Text="ไม่พบหนังสือที่ค้นหา" FontWeight="Bold" FontSize="44"
                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,30,0,0" />
                            <TextBlock Text="ลองเปลี่ยนคำค้น หรือเลือกหมวดอื่น" FontSize="30"
                                       Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,12,0,0" />
                            <Button Content="ดูหนังสือทั้งหมด" Command="{Binding ResetBrowseCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Margin="0,34,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===================== INITIAL LOADING (skeleton) ===================== -->
            <Grid Visibility="{Binding IsInitialLoading, Converter={StaticResource BoolToVis}}">
                <Rectangle Fill="{DynamicResource BackgroundGradientBrush}" />

                <!-- header placeholder -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="48,46,0,0">
                    <Border Width="84" Height="84" CornerRadius="20" Background="#33FFFFFF" />
                    <Border Width="380" Height="46" CornerRadius="12" Background="#33FFFFFF"
                            VerticalAlignment="Center" Margin="22,0,0,0" />
                </StackPanel>

                <!-- body panel placeholder -->
                <Border VerticalAlignment="Bottom" Height="1660" Background="{StaticResource PanelBrush}" CornerRadius="44,44,0,0">
                    <Grid Margin="44,40,44,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Height="116" CornerRadius="26" Background="#0F000000" />
                        <WrapPanel Grid.Row="1" Margin="0,26,0,0">
                            <Border CornerRadius="16" Width="140" Height="64" Background="#0F000000" Margin="0,0,16,16" />
                            <Border CornerRadius="16" Width="200" Height="64" Background="#0F000000" Margin="0,0,16,16" />
                            <Border CornerRadius="16" Width="170" Height="64" Background="#0F000000" Margin="0,0,16,16" />
                            <Border CornerRadius="16" Width="220" Height="64" Background="#0F000000" Margin="0,0,16,16" />
                            <Border CornerRadius="16" Width="150" Height="64" Background="#0F000000" Margin="0,0,16,16" />
                        </WrapPanel>
                        <UniformGrid Grid.Row="2" Columns="3" Margin="-12,30,-12,0" VerticalAlignment="Top">
                            <Border CornerRadius="20" Height="500" Background="#0F000000" Margin="12" />
                            <Border CornerRadius="20" Height="500" Background="#0F000000" Margin="12" />
                            <Border CornerRadius="20" Height="500" Background="#0F000000" Margin="12" />
                            <Border CornerRadius="20" Height="500" Background="#0F000000" Margin="12" />
                            <Border CornerRadius="20" Height="500" Background="#0F000000" Margin="12" />
                            <Border CornerRadius="20" Height="500" Background="#0F000000" Margin="12" />
                        </UniformGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===================== DETAIL MODAL ===================== -->
            <!-- Visibility is driven by IsDetailOpen via the trigger below (not a direct
                 binding) so the modal can fade+scale IN on open and fade OUT before it
                 collapses. Same VM flag, same behaviour — just animated. -->
            <Grid x:Name="DetailModal" Visibility="Collapsed">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDetailOpen}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0.18">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value><Visibility>Visible</Visibility></DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.14">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0.14">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.14">
                                                    <DiscreteObjectKeyFrame.Value><Visibility>Collapsed</Visibility></DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Background="#B3091122" />
                <Border Width="880" MaxHeight="1640" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{StaticResource SurfaceBrush}" CornerRadius="36"
                        RenderTransformOrigin="0.5,0.5"
                        DataContext="{Binding SelectedBook}">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Border.RenderTransform>
                    <!-- card scales 0.95 -> 1 as the overlay fades in (self-target property
                         path, since a Style storyboard can't reference an element by name) -->
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsDetailOpen, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                 From="0.95" To="1" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                 From="0.95" To="1" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="0.97" Duration="0:0:0.14" />
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.97" Duration="0:0:0.14" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Cover. No-cover fill follows the theme (PrimaryBrush) so the modal head
                             matches the chosen colour; a real cover (blur-bg + full) covers it. -->
                        <Border Grid.Row="0" Height="720" CornerRadius="36,36,0,0" ClipToBounds="True"
                                Background="{DynamicResource PrimaryBrush}">
                            <Grid>
                                <!-- Netflix-style cover: blurred fill behind, full cover in front so
                                     any aspect ratio shows complete (no crop) and the frame stays full. -->
                                <Image Source="{Binding Cover}" Stretch="UniformToFill"
                                       Visibility="{Binding HasCover, Converter={StaticResource BoolToVis}}">
                                    <Image.Effect>
                                        <BlurEffect Radius="60" KernelType="Gaussian" RenderingBias="Performance" />
                                    </Image.Effect>
                                </Image>
                                <Border Background="#40000000"
                                        Visibility="{Binding HasCover, Converter={StaticResource BoolToVis}}" />
                                <Image Source="{Binding Cover}" Stretch="Uniform"
                                       Visibility="{Binding HasCover, Converter={StaticResource BoolToVis}}" />
                                <Border VerticalAlignment="Bottom" Height="240">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#00000000" Offset="0" />
                                            <GradientStop Color="#D9000000" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <StackPanel VerticalAlignment="Bottom" Margin="44,0,44,34">
                                    <Border HorizontalAlignment="Left" CornerRadius="16" Background="#33FFFFFF" Padding="18,8" Margin="0,0,0,16">
                                        <TextBlock Text="{Binding Category}" Foreground="White" FontWeight="SemiBold" FontSize="26" />
                                    </Border>
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold"
                                               FontSize="52" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Info -->
                        <StackPanel Grid.Row="1" Margin="44,32,44,40">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="เลขทะเบียน" FontSize="26" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding RegNo}" FontFamily="{StaticResource MonoFontFamily}"
                                               FontWeight="Bold" FontSize="38" Foreground="{StaticResource TextBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Visibility="{Binding HasPublisher, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="สำนักพิมพ์" FontSize="26" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding Publisher}" FontWeight="SemiBold" FontSize="34"
                                               Foreground="{StaticResource TextBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>

                            <Border Margin="0,28,0,0" Background="{StaticResource PrimaryTintBrush}"
                                    BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" CornerRadius="22" Padding="28,22"
                                    Visibility="{Binding HasShelf, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="72" Height="72" CornerRadius="18" Background="{StaticResource PrimaryBrush}" Margin="0,0,22,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Width="9" Height="34" CornerRadius="2" Background="White" Margin="2,0" />
                                            <Border Width="9" Height="34" CornerRadius="2" Background="#CCFFFFFF" Margin="2,0" />
                                            <Border Width="9" Height="34" CornerRadius="2" Background="White" Margin="2,0" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="ตำแหน่งหนังสือ · ชั้นวาง" FontSize="26" Foreground="{StaticResource TextSecondBrush}" />
                                        <TextBlock Text="{Binding Shelf}" FontWeight="Bold" FontSize="40"
                                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,2,0,0" />

                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Button Content="ปิด" Margin="0,30,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding DataContext.CloseDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Close X -->
                <Button Width="84" Height="84" VerticalAlignment="Top" HorizontalAlignment="Right"
                        Margin="0,60,80,0" Cursor="Hand"
                        Command="{Binding CloseDetailCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#33FFFFFF" CornerRadius="42" BorderBrush="#4DFFFFFF" BorderThickness="1">
                                <Grid Width="34" Height="34">
                                    <Line X1="7" Y1="7" X2="27" Y2="27" Stroke="White" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    <Line X1="27" Y1="7" X2="7" Y2="27" Stroke="White" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ===================== WELCOME (idle screen) =====================
                 Shown by the idle timer (ShowWelcome resets the grid behind first).
                 Tap anywhere = enter grid; tap search = enter + focus; tap chip =
                 enter + filter. Fades in/out. Sits topmost so it covers everything. -->
            <Grid x:Name="WelcomeOverlay" Visibility="Collapsed"
                  Background="#01000000" MouseDown="Welcome_Dismiss" TouchDown="Welcome_Dismiss">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsWelcomeVisible}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0.24">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value><Visibility>Visible</Visibility></DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0.18">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.18">
                                                    <DiscreteObjectKeyFrame.Value><Visibility>Collapsed</Visibility></DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <!-- branding background (same layering as the browse view) -->
                <Rectangle Fill="{DynamicResource BackgroundGradientBrush}" />
                <Image Source="{Binding BackgroundImage}" Stretch="UniformToFill"
                       Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />
                <Border Background="#73091226" />

                <!-- content: logo + welcome + count + big search + category chips -->
                <StackPanel x:Name="WelcomeContent" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Width="920" RenderTransformOrigin="0.5,0.5">
                    <StackPanel.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </StackPanel.RenderTransform>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWelcomeVisible}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" From="0.96" To="1" Duration="0:0:0.24">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" From="0.96" To="1" Duration="0:0:0.24">
                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Image Source="{Binding LogoImage}" Stretch="Uniform" Height="170" HorizontalAlignment="Center"
                           Visibility="{Binding HasLogo, Converter={StaticResource BoolToVis}}" Margin="0,0,0,44" />

                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                               Foreground="White" FontWeight="Bold" FontSize="76" LineHeight="86">
                        <Run Text="ยินดีต้อนรับสู่" /><LineBreak /><Run Text="{Binding DisplayName, Mode=OneWay}" />
                    </TextBlock>

                    <TextBlock HorizontalAlignment="Center" Margin="0,22,0,0">
                        <Run Text="{Binding BookCount, Mode=OneWay}" FontFamily="{StaticResource MonoFontFamily}"
                             FontWeight="Bold" FontSize="40" Foreground="White" />
                        <Run Text=" เล่มในห้องสมุด" FontSize="34" Foreground="#D9FFFFFF" />
                    </TextBlock>

                    <!-- big search box: a tap-target (not a live TextBox); enters the grid + focuses the real one -->
                    <Border MouseDown="Welcome_TapSearch" TouchDown="Welcome_TapSearch" Cursor="Hand"
                            Background="{StaticResource SurfaceBrush}" CornerRadius="34" Height="132" Margin="0,64,0,0"
                            Padding="40,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="52" Height="52" Margin="0,0,26,0" VerticalAlignment="Center">
                                <Ellipse Width="36" Height="36" Stroke="{StaticResource MutedBrush}" StrokeThickness="4"
                                         HorizontalAlignment="Left" VerticalAlignment="Top" Margin="1" />
                                <Line X1="32" Y1="32" X2="50" Y2="50" Stroke="{StaticResource MutedBrush}"
                                      StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Grid>
                            <TextBlock Grid.Column="1" Text="แตะเพื่อค้นหาหนังสือ" FontSize="40"
                                       Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- category chips: same Categories collection; tap enters grid filtered -->
                    <ItemsControl ItemsSource="{Binding Categories}" Margin="0,40,0,0" HorizontalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="8" Cursor="Hand"
                                        Template="{StaticResource WelcomeChipTemplate}"
                                        Command="{Binding DataContext.WelcomeSelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding Name}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="แตะที่ใดก็ได้เพื่อเริ่มใช้งาน" HorizontalAlignment="Center"
                               FontSize="30" Foreground="#A6FFFFFF" Margin="0,56,0,0" />
                </StackPanel>
            </Grid>
            </Grid>
            <!-- /PortraitRoot -->

            <!-- ============================================================
                 LANDSCAPE ROOT — shown when IsLandscape. L1 = scaffold only
                 (shared background + placeholder); L2-L4 fill the per-page
                 landscape layouts. Shares all styles/templates with portrait.
                 ============================================================ -->
            <Grid x:Name="LandscapeRoot" Visibility="{Binding IsLandscape, Converter={StaticResource BoolToVis}}">
                <Rectangle Fill="{DynamicResource BackgroundGradientBrush}" />
                <Image Source="{Binding BackgroundImage}" Stretch="UniformToFill"
                       Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />
                <Border Background="#33000000"
                        Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />
                <!-- ===================== BROWSE (landscape) =====================
                     Same structure as portrait (header + search + chips + grid) laid
                     out wide, grid 4 columns. Shares CardButtonStyle + ChipButtonTemplate
                     so restyle + press/colour animations carry over. -->
                <Grid Visibility="{Binding IsBrowseVisible, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="64,40,64,26">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="{Binding LogoImage}" Stretch="Uniform" Height="80" Margin="0,0,22,0"
                                   Visibility="{Binding HasLogo, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="Bold"
                                       FontSize="46" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,22,0">
                            <TextBlock HorizontalAlignment="Right">
                                <Run Text="{Binding BookCount, Mode=OneWay}" FontFamily="{StaticResource MonoFontFamily}"
                                     FontWeight="Bold" FontSize="34" Foreground="White" />
                                <Run Text=" เล่ม" FontSize="28" Foreground="#CCFFFFFF" />
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Right" FontSize="24" Foreground="#B3FFFFFF" Margin="0,4,0,0">
                                <Run Text="อัปเดต " /><Run Text="{Binding LastUpdated, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="2" Style="{StaticResource GearButtonStyle}"
                                AutomationProperties.Name="ตั้งค่า" VerticalAlignment="Center"
                                Command="{Binding OpenSettingsCommand}" />
                    </Grid>

                    <!-- Body panel. Fill is its own brush so the opacity slider fades only the
                         panel surface (branding shows through) — content on top stays opaque. -->
                    <Border Grid.Row="1" CornerRadius="44,44,0,0">
                        <Border.Background>
                            <SolidColorBrush Color="{StaticResource PanelColor}" Opacity="{Binding BackgroundOpacity}" />
                        </Border.Background>
                        <Grid Margin="64,40,64,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Search (full width) -->
                            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="2"
                                    CornerRadius="26" Height="108" Padding="28,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" Width="44" Height="44" Margin="0,0,18,0" VerticalAlignment="Center">
                                        <Ellipse Width="30" Height="30" Stroke="{StaticResource MutedBrush}" StrokeThickness="3"
                                                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="1" />
                                        <Line X1="27" Y1="27" X2="42" Y2="42" Stroke="{StaticResource MutedBrush}"
                                              StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Grid>
                                    <Grid Grid.Column="1">
                                        <TextBlock Text="ค้นหาชื่อหนังสือ เลขทะเบียน หมวดหมู่ หรือสำนักพิมพ์"
                                                   FontSize="34" Foreground="{StaticResource MutedBrush}"
                                                   VerticalAlignment="Center" IsHitTestVisible="False"
                                                   Visibility="{Binding HasQuery, Converter={StaticResource InvBoolToVis}}" />
                                        <TextBox x:Name="SearchBoxL" Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="34" Foreground="{StaticResource TextBrush}"
                                                 FontFamily="{StaticResource AppFontFamily}" ContextMenu="{x:Null}"
                                                 Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"
                                                 CaretBrush="{StaticResource PrimaryBrush}" />
                                    </Grid>
                                    <Button Grid.Column="2" Command="{Binding ClearQueryCommand}" Width="56" Height="56"
                                            Cursor="Hand" VerticalAlignment="Center"
                                            Visibility="{Binding HasQuery, Converter={StaticResource BoolToVis}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="#F1F5FA" CornerRadius="28">
                                                    <Grid Width="28" Height="28">
                                                        <Line X1="6" Y1="6" X2="22" Y2="22" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                        <Line X1="22" Y1="6" X2="6" Y2="22" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Category chips (shared template) -->
                            <ItemsControl Grid.Row="1" Margin="0,24,0,0" ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,16,16" Cursor="Hand"
                                                Template="{StaticResource ChipButtonTemplate}"
                                                Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Name}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Result count -->
                            <TextBlock Grid.Row="2" Margin="2,4,0,16">
                                <Run Text="พบ " FontSize="30" Foreground="{StaticResource TextSecondBrush}" />
                                <Run Text="{Binding FilteredCount, Mode=OneWay}" FontFamily="{StaticResource MonoFontFamily}"
                                     FontWeight="Bold" FontSize="30" Foreground="{StaticResource TextBrush}" />
                                <Run Text=" เล่ม" FontSize="30" Foreground="{StaticResource TextSecondBrush}" />
                            </TextBlock>

                            <!-- Grid: 4 columns (shared CardButtonStyle), virtualized rows -->
                            <ItemsControl x:Name="CardsHostL" Grid.Row="3"
                                          ItemsSource="{Binding BookRows}" Margin="-12,0,-12,24"
                                          Visibility="{Binding IsEmpty, Converter={StaticResource InvBoolToVis}}"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.ScrollUnit="Pixel"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl.Template>
                                    <ControlTemplate TargetType="ItemsControl">
                                        <ScrollViewer CanContentScroll="True" Focusable="False"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </ControlTemplate>
                                </ItemsControl.Template>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><VirtualizingStackPanel Orientation="Vertical" /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ItemsControl ItemsSource="{Binding Cards}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><UniformGrid Columns="4" /></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource CardButtonStyle}"
                                                            Command="{Binding DataContext.SelectBookCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Empty state -->
                            <StackPanel Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                                <Border Width="180" Height="180" CornerRadius="90" Background="{DynamicResource PrimaryTintBrush}" HorizontalAlignment="Center">
                                    <Grid Width="80" Height="80">
                                        <Ellipse Width="56" Height="56" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="5"
                                                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2" />
                                        <Line X1="52" Y1="52" X2="76" Y2="76" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="5" StrokeStartLineCap="Round" />
                                    </Grid>
                                </Border>
                                <TextBlock Text="ไม่พบหนังสือที่ค้นหา" FontWeight="Bold" FontSize="44"
                                           Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,30,0,0" />
                                <TextBlock Text="ลองเปลี่ยนคำค้น หรือเลือกหมวดอื่น" FontSize="30"
                                           Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center" Margin="0,12,0,0" />
                                <Button Content="ดูหนังสือทั้งหมด" Command="{Binding ResetBrowseCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Margin="0,34,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===================== DETAIL MODAL (landscape, 2-pane) =====================
                     Left = cover/colour pane (blur-bg, full, no crop) with title/publisher;
                     right = details. Same IsDetailOpen flag + fade/scale as portrait. -->
                <Grid x:Name="DetailModalL" Visibility="Collapsed">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDetailOpen}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0.18">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0"><DiscreteObjectKeyFrame.Value><Visibility>Visible</Visibility></DiscreteObjectKeyFrame.Value></DiscreteObjectKeyFrame>
                                                </ObjectAnimationUsingKeyFrames>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.16"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction></DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.14"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0.14">
                                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.14"><DiscreteObjectKeyFrame.Value><Visibility>Collapsed</Visibility></DiscreteObjectKeyFrame.Value></DiscreteObjectKeyFrame>
                                                </ObjectAnimationUsingKeyFrames>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Border Background="#B3091122" />
                    <Border Width="1280" Height="640" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Background="{StaticResource SurfaceBrush}" CornerRadius="36" ClipToBounds="True"
                            RenderTransformOrigin="0.5,0.5" DataContext="{Binding SelectedBook}">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsDetailOpen, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" From="0.95" To="1" Duration="0:0:0.2"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" From="0.95" To="1" Duration="0:0:0.2"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="0.97" Duration="0:0:0.14" />
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.97" Duration="0:0:0.14" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="500" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- LEFT pane: cover/colour (blur-bg full, no crop). No-cover fill follows
                                 the theme (PrimaryBrush); a real cover covers it. -->
                            <Border Grid.Column="0" Background="{DynamicResource PrimaryBrush}" ClipToBounds="True">
                                <Grid>
                                    <Image Source="{Binding Cover}" Stretch="UniformToFill" Visibility="{Binding HasCover, Converter={StaticResource BoolToVis}}">
                                        <Image.Effect><BlurEffect Radius="60" KernelType="Gaussian" RenderingBias="Performance" /></Image.Effect>
                                    </Image>
                                    <Border Background="#40000000" Visibility="{Binding HasCover, Converter={StaticResource BoolToVis}}" />
                                    <Image Source="{Binding Cover}" Stretch="Uniform" Visibility="{Binding HasCover, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Text="{Binding Category}" Foreground="#CCFFFFFF" FontWeight="SemiBold" FontSize="26"
                                               VerticalAlignment="Top" HorizontalAlignment="Left" Margin="40,36,0,0" />
                                    <Border VerticalAlignment="Bottom" Height="280">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0" />
                                                <GradientStop Color="#D9000000" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel VerticalAlignment="Bottom" Margin="40,0,40,40">
                                        <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="44" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Publisher}" Foreground="#CCFFFFFF" FontSize="28" Margin="0,12,0,0"
                                                   Visibility="{Binding HasPublisher, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- RIGHT pane: details -->
                            <Grid Grid.Column="1" Margin="48,40,48,40">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="รายละเอียดหนังสือ" FontSize="24" Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="40" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                        <Border HorizontalAlignment="Left" CornerRadius="16" Background="{StaticResource PrimaryTintBrush}" Padding="18,8" Margin="0,16,0,0">
                                            <TextBlock Text="{Binding Category}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" FontSize="24" />
                                        </Border>
                                    </StackPanel>
                                    <Button Grid.Column="1" VerticalAlignment="Top" Width="64" Height="64" Cursor="Hand"
                                            Command="{Binding DataContext.CloseDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{StaticResource PanelBrush}" CornerRadius="32"
                                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="2">
                                                    <Grid Width="26" Height="26">
                                                        <Line X1="6" Y1="6" X2="20" Y2="20" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                        <Line X1="20" Y1="6" X2="6" Y2="20" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="20" Padding="28,22" Margin="0,0,10,0">
                                            <StackPanel>
                                                <TextBlock Text="เลขทะเบียน" FontSize="24" Foreground="{StaticResource MutedBrush}" />
                                                <TextBlock Text="{Binding RegNo}" FontFamily="{StaticResource MonoFontFamily}" FontWeight="Bold" FontSize="34" Foreground="{StaticResource TextBrush}" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="20" Padding="28,22" Margin="10,0,0,0"
                                                Visibility="{Binding HasPublisher, Converter={StaticResource BoolToVis}}">
                                            <StackPanel>
                                                <TextBlock Text="สำนักพิมพ์" FontSize="24" Foreground="{StaticResource MutedBrush}" />
                                                <TextBlock Text="{Binding Publisher}" FontWeight="SemiBold" FontSize="30" Foreground="{StaticResource TextBrush}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <Border Margin="0,20,0,0" Background="{StaticResource PrimaryTintBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1" CornerRadius="22" Padding="28,22"
                                            Visibility="{Binding HasShelf, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="72" Height="72" CornerRadius="18" Background="{StaticResource PrimaryBrush}" Margin="0,0,22,0">
                                                <Viewbox Width="40" Height="40">
                                                    <Path Fill="White" Data="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z" />
                                                </Viewbox>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="ตำแหน่งหนังสือ · ชั้นวาง" FontSize="24" Foreground="{StaticResource TextSecondBrush}" />
                                                <TextBlock Text="{Binding Shelf}" FontWeight="Bold" FontSize="38" Foreground="{StaticResource PrimaryBrush}" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <Button Grid.Row="2" Content="ปิด" Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding DataContext.CloseDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===================== WELCOME (landscape) =====================
                     Header bar + centred title/subtitle/search/chips. Same IsWelcomeVisible
                     flag, dismiss handlers, fade as portrait. -->
                <Grid x:Name="WelcomeOverlayL"
                      Visibility="{Binding IsWelcomeVisible, Converter={StaticResource BoolToVis}}"
                      Background="#01000000" MouseDown="Welcome_Dismiss" TouchDown="Welcome_Dismiss">

                    <Rectangle Fill="{DynamicResource BackgroundGradientBrush}" />
                    <Image Source="{Binding BackgroundImage}" Stretch="UniformToFill"
                           Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}" />
                    <Border Background="#73091226" />

                    <!-- header bar -->
                    <Grid VerticalAlignment="Top" Margin="64,40,64,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="{Binding LogoImage}" Stretch="Uniform" Height="72" Margin="0,0,20,0"
                                   Visibility="{Binding HasLogo, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="Bold"
                                       FontSize="40" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,20,0">
                            <TextBlock HorizontalAlignment="Right">
                                <Run Text="{Binding BookCount, Mode=OneWay}" FontFamily="{StaticResource MonoFontFamily}" FontWeight="Bold" FontSize="30" Foreground="White" />
                                <Run Text=" เล่ม" FontSize="24" Foreground="#CCFFFFFF" />
                            </TextBlock>
                            <TextBlock HorizontalAlignment="Right" FontSize="20" Foreground="#B3FFFFFF" Margin="0,4,0,0">
                                <Run Text="อัปเดต " /><Run Text="{Binding LastUpdated, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="2" Style="{StaticResource GearButtonStyle}" AutomationProperties.Name="ตั้งค่า"
                                VerticalAlignment="Center" Command="{Binding OpenSettingsCommand}" />
                    </Grid>

                    <!-- centred content -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="1180" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </StackPanel.RenderTransform>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWelcomeVisible}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" From="0.96" To="1" Duration="0:0:0.24"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" From="0.96" To="1" Duration="0:0:0.24"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="ยินดีต้อนรับสู่" HorizontalAlignment="Center" Foreground="#CCFFFFFF" FontWeight="SemiBold" FontSize="34" />
                        <TextBlock Text="{Binding DisplayName, Mode=OneWay}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                                   Foreground="White" FontWeight="Bold" FontSize="72" Margin="0,6,0,0" />
                        <TextBlock HorizontalAlignment="Center" Margin="0,16,0,0">
                            <Run Text="ค้นหาหนังสือกว่า " FontSize="32" Foreground="#D9FFFFFF" />
                            <Run Text="{Binding BookCount, Mode=OneWay}" FontFamily="{StaticResource MonoFontFamily}" FontWeight="Bold" FontSize="32" Foreground="White" />
                            <Run Text=" เล่ม ได้ง่าย ๆ เพียงปลายนิ้ว" FontSize="32" Foreground="#D9FFFFFF" />
                        </TextBlock>

                        <!-- big search (tap-target -> dismiss + focus SearchBoxL) -->
                        <Border MouseDown="Welcome_TapSearch" TouchDown="Welcome_TapSearch" Cursor="Hand"
                                Background="{StaticResource SurfaceBrush}" CornerRadius="34" Height="128" Margin="0,48,0,0" Padding="40,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="48" Height="48" Margin="0,0,24,0" VerticalAlignment="Center">
                                    <Ellipse Width="34" Height="34" Stroke="{StaticResource MutedBrush}" StrokeThickness="4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="1" />
                                    <Line X1="30" Y1="30" X2="46" Y2="46" Stroke="{StaticResource MutedBrush}" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Grid>
                                <TextBlock Grid.Column="1" Text="พิมพ์ชื่อหนังสือ เลขทะเบียน หมวดหมู่ หรือชั้นวาง..." FontSize="36"
                                           Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                                <Border Grid.Column="2" Width="76" Height="76" CornerRadius="38" Background="{StaticResource PrimaryBrush}" VerticalAlignment="Center">
                                    <Grid Width="40" Height="40">
                                        <Ellipse Width="26" Height="26" Stroke="White" StrokeThickness="4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2" />
                                        <Line X1="24" Y1="24" X2="38" Y2="38" Stroke="White" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- chips (shared WelcomeChipTemplate) -->
                        <ItemsControl ItemsSource="{Binding Categories}" Margin="0,36,0,0" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="8" Cursor="Hand" Template="{StaticResource WelcomeChipTemplate}"
                                            Command="{Binding DataContext.WelcomeSelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Name}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock Text="แตะที่ช่องค้นหาเพื่อเริ่มพิมพ์ หรือเลือกหมวดหมู่ด้านบน" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                               FontSize="28" Foreground="#A6FFFFFF" Margin="0,0,0,48" />
                </Grid>

                <!-- ===================== INITIAL LOADING (landscape skeleton) ===================== -->
                <Grid Visibility="{Binding IsInitialLoading, Converter={StaticResource BoolToVis}}">
                    <Rectangle Fill="{DynamicResource BackgroundGradientBrush}" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="64,46,0,0">
                        <Border Width="80" Height="80" CornerRadius="20" Background="#33FFFFFF" />
                        <Border Width="360" Height="44" CornerRadius="12" Background="#33FFFFFF" VerticalAlignment="Center" Margin="22,0,0,0" />
                    </StackPanel>
                    <Border VerticalAlignment="Bottom" Height="900" Background="{StaticResource PanelBrush}" CornerRadius="44,44,0,0">
                        <Grid Margin="64,40,64,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Height="108" CornerRadius="26" Background="#0F000000" />
                            <WrapPanel Grid.Row="1" Margin="0,24,0,0">
                                <Border CornerRadius="16" Width="140" Height="64" Background="#0F000000" Margin="0,0,16,16" />
                                <Border CornerRadius="16" Width="200" Height="64" Background="#0F000000" Margin="0,0,16,16" />
                                <Border CornerRadius="16" Width="170" Height="64" Background="#0F000000" Margin="0,0,16,16" />
                                <Border CornerRadius="16" Width="220" Height="64" Background="#0F000000" Margin="0,0,16,16" />
                                <Border CornerRadius="16" Width="150" Height="64" Background="#0F000000" Margin="0,0,16,16" />
                                <Border CornerRadius="16" Width="180" Height="64" Background="#0F000000" Margin="0,0,16,16" />
                            </WrapPanel>
                            <UniformGrid Grid.Row="2" Columns="4" Margin="-12,28,-12,0" VerticalAlignment="Top">
                                <Border CornerRadius="20" Height="430" Background="#0F000000" Margin="12" />
                                <Border CornerRadius="20" Height="430" Background="#0F000000" Margin="12" />
                                <Border CornerRadius="20" Height="430" Background="#0F000000" Margin="12" />
                                <Border CornerRadius="20" Height="430" Background="#0F000000" Margin="12" />
                            </UniformGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            <!-- ===== SHARED OVERLAY: settings/PIN/lock (portrait + landscape) ===== -->
            <!-- ===================== ADMIN SETTINGS OVERLAY (Phase 5) ===================== -->
            <!-- Visibility driven by IsOpen via the trigger so the overlay fades in/out
                 (panels also slide up via OverlayPanelSlideStyle) instead of blinking. -->
            <Grid x:Name="SettingsOverlay" Panel.ZIndex="50" DataContext="{Binding Settings}" Visibility="Collapsed">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOpen}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0.2">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                                    <DiscreteObjectKeyFrame.Value><Visibility>Visible</Visibility></DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.16">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0.16">
                                                <DiscreteObjectKeyFrame KeyTime="0:0:0.16">
                                                    <DiscreteObjectKeyFrame.Value><Visibility>Collapsed</Visibility></DiscreteObjectKeyFrame.Value>
                                                </DiscreteObjectKeyFrame>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Background="#D90B1426" />

                <!-- PIN keypad (gate + change-PIN) -->
                <Border Width="780" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{StaticResource SurfaceBrush}" CornerRadius="40" Padding="56,48"
                        Style="{StaticResource OverlayKeypadSlideStyle}" RenderTransformOrigin="0.5,0.5"
                        Visibility="{Binding ShowKeypad, Converter={StaticResource BoolToVis}}">
                    <Border.RenderTransform>
                        <TranslateTransform Y="0" />
                    </Border.RenderTransform>
                    <StackPanel>
                        <TextBlock Text="{Binding Pad.Title}" FontWeight="Bold" FontSize="48"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding Pad.Subtitle}" FontSize="30"
                                   Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"
                                   Margin="0,10,0,0" TextAlignment="Center" />

                        <!-- entered digits, masked -->
                        <Border x:Name="PinMask" Background="{StaticResource PanelBrush}" CornerRadius="20" Height="96"
                                Margin="0,30,0,0" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <TextBlock Text="{Binding Pad.Mask}" FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="56" Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <!-- error / attempts -->
                        <TextBlock Text="{Binding Pad.ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                                   FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center"
                                   Margin="0,18,0,0" TextAlignment="Center" TextWrapping="Wrap"
                                   Visibility="{Binding Pad.HasError, Converter={StaticResource BoolToVis}}" />

                        <!-- keypad: any key press bounces the mask above (Button.Click bubbles
                             up here from every key) so the entered-digits readout feels responsive -->
                        <UniformGrid Columns="3" Margin="0,24,0,0">
                            <UniformGrid.Triggers>
                                <EventTrigger RoutedEvent="ButtonBase.Click">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PinMask" Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1.06" Duration="0:0:0.08" AutoReverse="True">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="PinMask" Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1.06" Duration="0:0:0.08" AutoReverse="True">
                                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </UniformGrid.Triggers>
                            <Button Content="1" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="1" />
                            <Button Content="2" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="2" />
                            <Button Content="3" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="3" />
                            <Button Content="4" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="4" />
                            <Button Content="5" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="5" />
                            <Button Content="6" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="6" />
                            <Button Content="7" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="7" />
                            <Button Content="8" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="8" />
                            <Button Content="9" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="9" />
                            <Button Content="ลบ" FontSize="34" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.BackspaceCommand}" />
                            <Button Content="0" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.PressCommand}" CommandParameter="0" />
                            <Button Content="ตกลง" FontSize="34" Style="{StaticResource KeypadButtonStyle}" Command="{Binding Pad.SubmitCommand}" />
                        </UniformGrid>

                        <!-- close (gate) / cancel (change-PIN) -->
                        <Button Content="ปิด" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CloseCommand}" Margin="0,28,0,0"
                                Visibility="{Binding ShowGate, Converter={StaticResource BoolToVis}}" />
                        <Button Content="ยกเลิก" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CancelChangePinCommand}" Margin="0,28,0,0"
                                Visibility="{Binding ShowChangePin, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </Border>

                <!-- lock screen -->
                <Border Width="780" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{StaticResource SurfaceBrush}" CornerRadius="40" Padding="56,56"
                        Style="{StaticResource OverlayLockSlideStyle}" RenderTransformOrigin="0.5,0.5"
                        Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}}">
                    <Border.RenderTransform>
                        <TranslateTransform Y="0" />
                    </Border.RenderTransform>
                    <StackPanel>
                        <Border Width="170" Height="170" CornerRadius="85" Background="#FBE9E7"
                                HorizontalAlignment="Center">
                            <Grid Width="78" Height="86" VerticalAlignment="Center">
                                <Border Width="78" Height="56" VerticalAlignment="Bottom" CornerRadius="14"
                                        Background="{StaticResource ErrorBrush}" />
                                <Border Width="46" Height="46" VerticalAlignment="Top" HorizontalAlignment="Center"
                                        BorderBrush="{StaticResource ErrorBrush}" BorderThickness="10,10,10,0"
                                        CornerRadius="23,23,0,0" />
                            </Grid>
                        </Border>
                        <TextBlock Text="PIN ถูกล็อก" FontWeight="Bold" FontSize="50"
                                   Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,30,0,0" />
                        <TextBlock Text="{Binding LockMessage}" FontSize="32" Foreground="{StaticResource TextSecondBrush}"
                                   HorizontalAlignment="Center" Margin="0,16,0,0" TextAlignment="Center" TextWrapping="Wrap" />
                        <Button Content="ปิด" Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CloseCommand}" Margin="0,36,0,0" />
                    </StackPanel>
                </Border>

                <!-- settings panel -->
                <Border Width="920" MaxHeight="1740" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Background="{StaticResource PanelBrush}" CornerRadius="40"
                        Style="{StaticResource OverlayPanelSlideStyle}" RenderTransformOrigin="0.5,0.5"
                        Visibility="{Binding ShowPanel, Converter={StaticResource BoolToVis}}">
                    <Border.RenderTransform>
                        <TranslateTransform Y="0" />
                    </Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- panel header -->
                        <Grid Grid.Row="0" Margin="48,40,40,8">
                            <TextBlock Text="ตั้งค่า" FontWeight="Bold" FontSize="52"
                                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                            <Button Width="76" Height="76" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Cursor="Hand" Command="{Binding CloseCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="38"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2">
                                            <Grid Width="30" Height="30">
                                                <Line X1="6" Y1="6" X2="24" Y2="24" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                <Line X1="24" Y1="6" X2="6" Y2="24" Stroke="{StaticResource TextSecondBrush}" StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled" Margin="0,8,0,0">
                            <StackPanel Margin="44,8,44,44">

                                <!-- การเชื่อมต่อ -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="28" Padding="36,32" Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock Text="การเชื่อมต่อ" FontWeight="Bold" FontSize="36"
                                                   Foreground="{StaticResource PrimaryBrush}" />
                                        <TextBlock Text="ที่อยู่เซิร์ฟเวอร์ (Base URL)" FontSize="28"
                                                   Foreground="{StaticResource MutedBrush}" Margin="0,22,0,10" />
                                        <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="2" CornerRadius="18" Padding="22,0" Height="92">
                                            <TextBox Text="{Binding BaseUrlInput, UpdateSourceTrigger=PropertyChanged}"
                                                     FontFamily="{StaticResource MonoFontFamily}" FontSize="32"
                                                     Foreground="{StaticResource TextBrush}" Background="Transparent"
                                                     BorderThickness="0" VerticalContentAlignment="Center" ContextMenu="{x:Null}"
                                                     CaretBrush="{StaticResource PrimaryBrush}" />
                                        </Border>
                                        <Grid Margin="0,22,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="บันทึก &amp; เชื่อมต่อ"
                                                    Style="{StaticResource PrimaryButtonStyle}" FontSize="32"
                                                    Command="{Binding SaveBaseUrlCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                                                    HorizontalAlignment="Left" />
                                            <Button Grid.Column="1" Content="ซิงก์ตอนนี้" Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding SyncNowCommand}" Margin="18,0,0,0" />
                                        </Grid>
                                        <!-- realtime connected/disconnected indicator (K2 item 3) -->
                                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                            <Ellipse Width="22" Height="22" VerticalAlignment="Center" Margin="0,2,14,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource ErrorBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource SuccessBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding ConnectionStatus}" FontSize="28"
                                                       Foreground="{StaticResource TextSecondBrush}"
                                                       VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="700" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- การแสดงผล -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="28" Padding="36,32" Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock Text="การแสดงผล" FontWeight="Bold" FontSize="36"
                                                   Foreground="{StaticResource PrimaryBrush}" />

                                        <!-- system name: local override per kiosk (K2 item 5) -->
                                        <TextBlock Text="ชื่อระบบ (เครื่องนี้)" FontSize="28"
                                                   Foreground="{StaticResource MutedBrush}" Margin="0,22,0,10" />
                                        <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="2" CornerRadius="18" Padding="22,0" Height="92">
                                            <TextBox Text="{Binding SystemNameInput, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="32" Foreground="{StaticResource TextBrush}" Background="Transparent"
                                                     BorderThickness="0" VerticalContentAlignment="Center" ContextMenu="{x:Null}"
                                                     CaretBrush="{StaticResource PrimaryBrush}" />
                                        </Border>
                                        <Grid Margin="0,14,0,0">
                                            <TextBlock Text="เว้นว่าง = ใช้ชื่อจากเซิร์ฟเวอร์" FontSize="24"
                                                       Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" />
                                            <Button HorizontalAlignment="Right" Content="บันทึกชื่อ" FontSize="28"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding SaveSystemNameCommand}" />
                                        </Grid>

                                        <!-- logo -->
                                        <Grid Margin="0,28,0,0">
                                            <TextBlock Text="โลโก้ (เครื่องนี้)" FontSize="30" Foreground="{StaticResource TextBrush}"
                                                       VerticalAlignment="Center" />
                                            <Button HorizontalAlignment="Right" Content="ลบโลโก้" Style="{StaticResource SecondaryButtonStyle}"
                                                    FontSize="28" Command="{Binding ToggleLogoCommand}" IsEnabled="{Binding LogoAvailable}"
                                                    Visibility="{Binding HideLogo, Converter={StaticResource InvBoolToVis}}" />
                                            <Button HorizontalAlignment="Right" Content="แสดงโลโก้" Style="{StaticResource SecondaryButtonStyle}"
                                                    FontSize="28" Command="{Binding ToggleLogoCommand}"
                                                    Visibility="{Binding HideLogo, Converter={StaticResource BoolToVis}}" />
                                        </Grid>

                                        <!-- background -->
                                        <Grid Margin="0,18,0,0">
                                            <TextBlock Text="ภาพพื้นหลัง (เครื่องนี้)" FontSize="30" Foreground="{StaticResource TextBrush}"
                                                       VerticalAlignment="Center" />
                                            <Button HorizontalAlignment="Right" Content="ลบพื้นหลัง" Style="{StaticResource SecondaryButtonStyle}"
                                                    FontSize="28" Command="{Binding ToggleBackgroundCommand}" IsEnabled="{Binding BackgroundAvailable}"
                                                    Visibility="{Binding HideBackground, Converter={StaticResource InvBoolToVis}}" />
                                            <Button HorizontalAlignment="Right" Content="แสดงพื้นหลัง" Style="{StaticResource SecondaryButtonStyle}"
                                                    FontSize="28" Command="{Binding ToggleBackgroundCommand}"
                                                    Visibility="{Binding HideBackground, Converter={StaticResource BoolToVis}}" />
                                        </Grid>

                                        <!-- panel opacity: fade the book-list surface so the branding shows through -->
                                        <Grid Margin="0,22,0,0">
                                            <TextBlock Text="ความโปร่งใสพื้นหลังรายการ" FontSize="30" Foreground="{StaticResource TextBrush}" />
                                            <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource MonoFontFamily}"
                                                       FontSize="30" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                                                       Text="{Binding BackgroundOpacityPercent, StringFormat={}{0:0}%}" />
                                        </Grid>
                                        <Slider Minimum="20" Maximum="100" Value="{Binding BackgroundOpacityPercent}"
                                                TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,12,0,0" Height="48" />

                                        <!-- UI scale -->
                                        <Grid Margin="0,30,0,0">
                                            <TextBlock Text="ขนาดการแสดงผล" FontSize="30" Foreground="{StaticResource TextBrush}" />
                                            <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource MonoFontFamily}"
                                                       FontSize="30" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                                                       Text="{Binding UiScalePercent, StringFormat={}{0:0}%}" />
                                        </Grid>
                                        <Slider Minimum="80" Maximum="120" Value="{Binding UiScalePercent}"
                                                TickFrequency="5" IsSnapToTickEnabled="True" Margin="0,12,0,0" Height="48" />

                                        <!-- display mode -->
                                        <TextBlock Text="โหมดการแสดงผล" FontSize="30" Foreground="{StaticResource TextBrush}" Margin="0,24,0,12" />
                                        <UniformGrid Columns="2">
                                            <Button Content="เต็มจอ (Kiosk)" Command="{Binding SetFullscreenCommand}" Cursor="Hand" Margin="0,0,9,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="M" Background="{StaticResource SurfaceBrush}" CornerRadius="18"
                                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" MinHeight="80">
                                                            <TextBlock x:Name="T" Text="{TemplateBinding Content}" FontSize="30" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsFullscreen}" Value="True">
                                                                <Setter TargetName="M" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter TargetName="M" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter TargetName="T" Property="Foreground" Value="White" />
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="หน้าต่าง (ทดสอบ)" Command="{Binding SetWindowedCommand}" Cursor="Hand" Margin="9,0,0,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="M" Background="{StaticResource SurfaceBrush}" CornerRadius="18"
                                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" MinHeight="80">
                                                            <TextBlock x:Name="T" Text="{TemplateBinding Content}" FontSize="30" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsFullscreen}" Value="False">
                                                                <Setter TargetName="M" Property="Background" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter TargetName="M" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                                <Setter TargetName="T" Property="Foreground" Value="White" />
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </UniformGrid>

                                        <!-- resolution (K2 item 4): portrait presets + custom W x H -->
                                        <TextBlock Text="ความละเอียด / การวางแนวจอ" FontSize="30"
                                                   Foreground="{StaticResource TextBrush}" Margin="0,26,0,12" />
                                        <UniformGrid Columns="2">
                                            <Button Content="1080 × 1920 (แนวตั้ง)" Command="{Binding SetPortraitPresetCommand}"
                                                    Cursor="Hand" HorizontalAlignment="Stretch" Margin="0,0,7,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="M" Background="{StaticResource SurfaceBrush}" CornerRadius="18"
                                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" MinHeight="80">
                                                            <TextBlock Text="{TemplateBinding Content}" FontSize="28" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="M" Property="Background" Value="{StaticResource PrimaryTintBrush}" />
                                                                <Setter TargetName="M" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            <Button Content="1920 × 1080 (แนวนอน)" Command="{Binding SetLandscapePresetCommand}"
                                                    Cursor="Hand" HorizontalAlignment="Stretch" Margin="7,0,0,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="M" Background="{StaticResource SurfaceBrush}" CornerRadius="18"
                                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" MinHeight="80">
                                                            <TextBlock Text="{TemplateBinding Content}" FontSize="28" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="M" Property="Background" Value="{StaticResource PrimaryTintBrush}" />
                                                                <Setter TargetName="M" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </UniformGrid>

                                        <TextBlock Text="หรือกำหนดเอง (กว้าง × สูง)" FontSize="26"
                                                   Foreground="{StaticResource MutedBrush}" Margin="0,18,0,10" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="2" CornerRadius="18" Padding="22,0" Height="88">
                                                <TextBox Text="{Binding ResWidthInput, UpdateSourceTrigger=PropertyChanged}"
                                                         FontFamily="{StaticResource MonoFontFamily}" FontSize="32" Foreground="{StaticResource TextBrush}"
                                                         Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"
                                                         ContextMenu="{x:Null}" CaretBrush="{StaticResource PrimaryBrush}" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="×" FontSize="34" Foreground="{StaticResource MutedBrush}"
                                                       VerticalAlignment="Center" Margin="18,0" />
                                            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="2" CornerRadius="18" Padding="22,0" Height="88">
                                                <TextBox Text="{Binding ResHeightInput, UpdateSourceTrigger=PropertyChanged}"
                                                         FontFamily="{StaticResource MonoFontFamily}" FontSize="32" Foreground="{StaticResource TextBrush}"
                                                         Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"
                                                         ContextMenu="{x:Null}" CaretBrush="{StaticResource PrimaryBrush}" />
                                            </Border>
                                        </Grid>
                                        <Button Content="ใช้ความละเอียดนี้" Style="{StaticResource SecondaryButtonStyle}" FontSize="28"
                                                Command="{Binding ApplyResolutionCommand}" HorizontalAlignment="Left" Margin="0,14,0,0" />
                                        <TextBlock Text="{Binding ResolutionStatus}" FontSize="26"
                                                   Foreground="{StaticResource TextSecondBrush}" Margin="0,12,0,0"
                                                   TextWrapping="Wrap" Visibility="{Binding ResolutionStatus, Converter={StaticResource StrToVis}}" />
                                    </StackPanel>
                                </Border>

                                <!-- ธีมสี (สีหลัก) -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="28" Padding="36,32" Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock Text="ธีมสี (สีหลัก)" FontWeight="Bold" FontSize="36"
                                                   Foreground="{StaticResource PrimaryBrush}" />
                                        <TextBlock Text="เปลี่ยนสีหลักของจอ — ปุ่ม/แท็บหมวด/ส่วนหัว/พื้นหลัง เปลี่ยนตามทันที (ตัวอักษรปรับให้อ่านออกอัตโนมัติ)"
                                                   FontSize="26" Foreground="{StaticResource TextSecondBrush}" TextWrapping="Wrap" Margin="0,8,0,18" />

                                        <!-- preset swatches -->
                                        <WrapPanel>
                                            <Button Style="{StaticResource ThemeSwatchButtonStyle}" Background="#1F5AA8" Command="{Binding SelectThemeSwatchCommand}" CommandParameter="#1F5AA8" />
                                            <Button Style="{StaticResource ThemeSwatchButtonStyle}" Background="#2E8B86" Command="{Binding SelectThemeSwatchCommand}" CommandParameter="#2E8B86" />
                                            <Button Style="{StaticResource ThemeSwatchButtonStyle}" Background="#2E9C7E" Command="{Binding SelectThemeSwatchCommand}" CommandParameter="#2E9C7E" />
                                            <Button Style="{StaticResource ThemeSwatchButtonStyle}" Background="#5A5BB8" Command="{Binding SelectThemeSwatchCommand}" CommandParameter="#5A5BB8" />
                                            <Button Style="{StaticResource ThemeSwatchButtonStyle}" Background="#C2622A" Command="{Binding SelectThemeSwatchCommand}" CommandParameter="#C2622A" />
                                            <Button Style="{StaticResource ThemeSwatchButtonStyle}" Background="#C0413B" Command="{Binding SelectThemeSwatchCommand}" CommandParameter="#C0413B" />
                                        </WrapPanel>

                                        <!-- hex + live preview -->
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="รหัสสี (HEX)" FontSize="26" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8" />
                                                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                                                        BorderThickness="2" CornerRadius="18" Padding="22,0" Height="88" HorizontalAlignment="Left" Width="320">
                                                    <TextBox Text="{Binding PrimaryColorInput, UpdateSourceTrigger=PropertyChanged}"
                                                             FontFamily="{StaticResource MonoFontFamily}" FontSize="32" Foreground="{StaticResource TextBrush}"
                                                             Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center"
                                                             ContextMenu="{x:Null}" CaretBrush="{StaticResource PrimaryBrush}" />
                                                </Border>
                                            </StackPanel>
                                            <!-- live preview: fill = PrimaryBrush, text = OnPrimaryBrush -->
                                            <Border Grid.Column="1" Width="200" Height="116" CornerRadius="18" VerticalAlignment="Bottom"
                                                    Background="{DynamicResource PrimaryBrush}">
                                                <TextBlock Text="ตัวอย่าง" FontSize="30" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource OnPrimaryBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>

                                        <!-- RGB sliders -->
                                        <Grid Margin="0,20,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="64" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="R" FontSize="28" FontWeight="SemiBold" Foreground="#C0413B" VerticalAlignment="Center" />
                                            <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ColorR}" VerticalAlignment="Center" Height="44" />
                                            <TextBlock Grid.Column="2" Text="{Binding ColorR, StringFormat={}{0:0}}" FontFamily="{StaticResource MonoFontFamily}" FontSize="26" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="64" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="G" FontSize="28" FontWeight="SemiBold" Foreground="#2E9C7E" VerticalAlignment="Center" />
                                            <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ColorG}" VerticalAlignment="Center" Height="44" />
                                            <TextBlock Grid.Column="2" Text="{Binding ColorG, StringFormat={}{0:0}}" FontFamily="{StaticResource MonoFontFamily}" FontSize="26" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="64" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="B" FontSize="28" FontWeight="SemiBold" Foreground="#1F5AA8" VerticalAlignment="Center" />
                                            <Slider Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding ColorB}" VerticalAlignment="Center" Height="44" />
                                            <TextBlock Grid.Column="2" Text="{Binding ColorB, StringFormat={}{0:0}}" FontFamily="{StaticResource MonoFontFamily}" FontSize="26" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>

                                        <Grid Margin="0,18,0,0">
                                            <TextBlock Text="{Binding ThemeColorStatus}" FontSize="26" Foreground="{StaticResource ErrorBrush}"
                                                       VerticalAlignment="Center" TextWrapping="Wrap"
                                                       Visibility="{Binding ThemeColorStatus, Converter={StaticResource StrToVis}}" />
                                            <Button HorizontalAlignment="Right" Content="คืนค่าเริ่มต้น" FontSize="28"
                                                    Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ResetThemeColorCommand}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ความปลอดภัย -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="28" Padding="36,32" Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock Text="ความปลอดภัย" FontWeight="Bold" FontSize="36"
                                                   Foreground="{StaticResource PrimaryBrush}" />
                                        <Button Content="เปลี่ยน PIN" Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding StartChangePinCommand}" HorizontalAlignment="Left" Margin="0,22,0,0" />
                                        <TextBlock Text="{Binding ChangePinResult}" FontSize="28" FontWeight="SemiBold"
                                                   Foreground="{StaticResource SuccessBrush}" Margin="0,16,0,0"
                                                   Visibility="{Binding ChangePinResult, Converter={StaticResource StrToVis}}" />
                                    </StackPanel>
                                </Border>

                                <!-- ระบบ -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="28" Padding="36,32" Margin="0,0,0,28">
                                    <StackPanel>
                                        <TextBlock Text="ระบบ" FontWeight="Bold" FontSize="36"
                                                   Foreground="{StaticResource PrimaryBrush}" />

                                        <!-- auto-start toggle -->
                                        <Grid Margin="0,22,0,0">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="เริ่มอัตโนมัติเมื่อเปิดเครื่อง" FontSize="30" Foreground="{StaticResource TextBrush}" />
                                                <TextBlock Text="เปิดโปรแกรมเองเมื่อผู้ใช้ Windows ล็อกอิน" FontSize="24"
                                                           Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <Button HorizontalAlignment="Right" Content="เปิดใช้งาน" Style="{StaticResource SecondaryButtonStyle}"
                                                    FontSize="28" Command="{Binding ToggleAutoStartCommand}"
                                                    Visibility="{Binding AutoStartEnabled, Converter={StaticResource InvBoolToVis}}" />
                                            <Button HorizontalAlignment="Right" Content="ปิด (กำลังเปิดอยู่)" Style="{StaticResource SecondaryButtonStyle}"
                                                    FontSize="28" Command="{Binding ToggleAutoStartCommand}"
                                                    Visibility="{Binding AutoStartEnabled, Converter={StaticResource BoolToVis}}" />
                                        </Grid>

                                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,26,0,0" />

                                        <!-- exit kiosk -->
                                        <TextBlock Text="ออกจากโหมด Kiosk" FontSize="30" Foreground="{StaticResource TextBrush}" Margin="0,26,0,2" />
                                        <TextBlock Text="ปิดโปรแกรม (ในโหมดเต็มจอ ออกได้ทางนี้เท่านั้น)" FontSize="24"
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <Button Content="ปิดโปรแกรม" Command="{Binding ExitKioskCommand}"
                                                HorizontalAlignment="Left" Cursor="Hand" Margin="0,18,0,0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="X" Background="{StaticResource ErrorBrush}" CornerRadius="16" Padding="36,16" MinHeight="72">
                                                        <TextBlock Text="{TemplateBinding Content}" FontSize="30" FontWeight="SemiBold"
                                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="X" Property="Background" Value="#B3433A" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- เกี่ยวกับ -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="28" Padding="36,32">
                                    <StackPanel>
                                        <TextBlock Text="เกี่ยวกับ" FontWeight="Bold" FontSize="36"
                                                   Foreground="{StaticResource PrimaryBrush}" />
                                        <TextBlock Text="{Binding AboutVersion}" FontSize="28"
                                                   Foreground="{StaticResource TextSecondBrush}" Margin="0,16,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== SHARED OVERLAY: error / unlicensed (portrait + landscape) ===== -->
            <!-- ===================== ERROR (unreachable) ===================== -->
            <Grid Panel.ZIndex="10">
                <!-- Below the Settings/PIN overlay (ZIndex 50) AND hidden while settings is open,
                     so the admin can always reach the PIN gate to fix the URL when offline. -->
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsErrorVisible}" Value="True" />
                                    <Condition Binding="{Binding Settings.IsOpen}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Background="#E60F1A33" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="820">
                    <Border Width="200" Height="200" CornerRadius="100" Background="#1FFFFFFF"
                            BorderBrush="#33FFFFFF" BorderThickness="1" HorizontalAlignment="Center">
                        <!-- wifi-off: signal arcs + dot with a diagonal slash -->
                        <Viewbox Width="104" Height="104" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Opacity="0.92" Data="M2,9 a14,14 0 0 1 20,0" />
                                <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Opacity="0.92" Data="M6,13 a9,9 0 0 1 12,0" />
                                <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Opacity="0.92" Data="M9.5,16.5 a4,4 0 0 1 5,0" />
                                <Ellipse Canvas.Left="10.6" Canvas.Top="18.4" Width="2.8" Height="2.8" Fill="White" />
                                <Line X1="3" Y1="3" X2="21" Y2="21" Stroke="White" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="เชื่อมต่อเซิร์ฟเวอร์ไม่ได้" Foreground="White" FontWeight="Bold"
                               FontSize="52" HorizontalAlignment="Center" Margin="0,40,0,0" />
                    <TextBlock Text="ระบบจะลองเชื่อมต่อใหม่อัตโนมัติ หรือกดปุ่มด้านล่างเพื่อลองอีกครั้ง"
                               Foreground="#D9FFFFFF" FontSize="30" TextAlignment="Center" TextWrapping="Wrap"
                               HorizontalAlignment="Center" Margin="0,16,0,0" />
                    <TextBlock Text="{Binding BaseUrl}" Foreground="#99FFFFFF" FontSize="26"
                               FontFamily="{StaticResource MonoFontFamily}" HorizontalAlignment="Center" Margin="0,18,0,0" />
                    <Button Content="ลองอีกครั้ง" Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Margin="0,40,0,0" />
                </StackPanel>
                <!-- always reachable so an admin can fix the URL when stuck offline -->
                <Button Style="{StaticResource GearButtonStyle}" AutomationProperties.Name="ตั้งค่า"
                        Command="{Binding OpenSettingsCommand}"
                        VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,48,48,0" />
            </Grid>

            <!-- ===================== UNLICENSED ===================== -->
            <Grid Panel.ZIndex="10">
                <!-- Same as the error overlay: below Settings (50) and hidden while settings is
                     open, so the PIN gate is always reachable. -->
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsUnlicensedVisible}" Value="True" />
                                    <Condition Binding="{Binding Settings.IsOpen}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Background="#E60F1A33" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="820">
                    <TextBlock Text="เซิร์ฟเวอร์ยังไม่ได้เปิดใช้งานลิขสิทธิ์" Foreground="White" FontWeight="Bold"
                               FontSize="46" TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#D9FFFFFF" FontSize="30"
                               TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,18,0,0" />
                    <Button Content="ลองอีกครั้ง" Command="{Binding RefreshCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Margin="0,40,0,0" />
                </StackPanel>
                <Button Style="{StaticResource GearButtonStyle}" AutomationProperties.Name="ตั้งค่า"
                        Command="{Binding OpenSettingsCommand}"
                        VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,48,48,0" />
            </Grid>

            <!-- ===================== FIRST-RUN SETUP (set server URL) =====================
                 Shown on a brand-new install (KioskSettings.Configured == false) so the kiosk
                 asks for the real server URL instead of failing against the default IP. Single
                 centred card (fills the design canvas in both portrait & landscape). The card
                 reuses the Settings VM's URL field + SaveBaseUrl (validate -> save -> rebind ->
                 reload); a reachable server marks the kiosk Configured and closes this overlay.
                 ZIndex 90: above content/error/settings, below the Notice (100). -->
            <Grid Panel.ZIndex="90" Visibility="{Binding IsSetupVisible, Converter={StaticResource BoolToVis}}">
                <Border Background="#F50F1A33" />
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="40" Padding="64,56"
                        HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="900"
                        DataContext="{Binding Settings}">
                    <StackPanel>
                        <TextBlock Text="ตั้งค่าเริ่มต้น" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold"
                                   FontSize="48" HorizontalAlignment="Center" />
                        <TextBlock Text="กรอกที่อยู่เซิร์ฟเวอร์ (Base URL) ของเครื่อง Admin เพื่อเริ่มใช้งาน"
                                   Foreground="{StaticResource TextSecondBrush}" FontSize="30" TextAlignment="Center"
                                   TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,18,0,0" />
                        <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="2" CornerRadius="18" Padding="22,0" Height="92" Margin="0,32,0,0">
                            <TextBox Text="{Binding BaseUrlInput, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{StaticResource MonoFontFamily}" FontSize="32"
                                     Foreground="{StaticResource TextBrush}" Background="Transparent"
                                     BorderThickness="0" VerticalContentAlignment="Center" ContextMenu="{x:Null}"
                                     CaretBrush="{StaticResource PrimaryBrush}" />
                        </Border>
                        <TextBlock Text="ตัวอย่าง: http://192.168.1.50:45269" Foreground="{StaticResource MutedBrush}"
                                   FontSize="24" HorizontalAlignment="Center" Margin="0,12,0,0"
                                   FontFamily="{StaticResource MonoFontFamily}" />
                        <Button Content="ทดสอบ และ บันทึก" Style="{StaticResource PrimaryButtonStyle}" FontSize="32"
                                Command="{Binding SaveBaseUrlCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InvBool}}"
                                HorizontalAlignment="Center" Margin="0,36,0,0" />
                        <TextBlock Text="{Binding ConnectionStatus}" Foreground="{StaticResource TextSecondBrush}"
                                   FontSize="28" TextAlignment="Center" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" Margin="0,24,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== SHARED OVERLAY: transient notice (e.g. admin PIN reset). Topmost so it
                 shows above settings/lock; tap anywhere or the button to dismiss; auto-hides. -->
            <Grid x:Name="NoticeOverlay" Panel.ZIndex="100" Visibility="{Binding IsNoticeVisible, Converter={StaticResource BoolToVis}}"
                  Background="#990F1A33" MouseDown="Notice_Dismiss" TouchDown="Notice_Dismiss">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="40" Padding="64,56"
                        HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="900">
                    <StackPanel>
                        <Border Width="150" Height="150" CornerRadius="75" Background="{StaticResource PrimaryTintBrush}"
                                HorizontalAlignment="Center">
                            <Viewbox Width="78" Height="78" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <!-- key glyph: signals a PIN/security change -->
                                    <Path Fill="{StaticResource PrimaryBrush}"
                                          Data="M21 10h-8.35A5.99 5.99 0 0 0 7 6a6 6 0 0 0 0 12 5.99 5.99 0 0 0 5.65-4H13l2 2 2-2 2 2 3-3-1-3zM7 14a2 2 0 1 1 0-4 2 2 0 0 1 0 4z" />
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <TextBlock Text="PIN ถูกรีเซ็ตแล้ว" Foreground="{StaticResource TextBrush}" FontWeight="Bold"
                                   FontSize="46" HorizontalAlignment="Center" Margin="0,32,0,0" />
                        <TextBlock Text="{Binding NoticeText}" Foreground="{StaticResource TextSecondBrush}" FontSize="32"
                                   TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,18,0,0" LineHeight="44" />
                        <Button Content="เข้าใจแล้ว" Command="{Binding DismissNoticeCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Margin="0,40,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>
    </Viewbox>
    </Grid>
</Window>
