<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================
         LibraryAdminPC design system (Task B). Mirrors the kiosk tokens
         so admin-pc and kiosk share one visual language. Everything here
         is x:Key'd (no implicit TargetType-only styles), so merging this
         dictionary changes nothing until a view explicitly references a
         token/style. Mono uses Consolas to echo the mockup's IBM Plex Mono
         (reg numbers / shelf codes) without bundling a second face.
         ============================================================ -->

    <FontFamily x:Key="AppFontFamily">pack://application:,,,/Assets/Fonts/#Anuphan</FontFamily>
    <FontFamily x:Key="MonoFontFamily">Consolas, Cascadia Mono, monospace</FontFamily>

    <!-- ===== Palette (admin-pc mockup tokens) ===== -->
    <Color x:Key="PrimaryColor">#1F5AA8</Color>
    <Color x:Key="PrimaryDarkColor">#17467F</Color>
    <Color x:Key="PrimaryTintColor">#EAF1FA</Color>
    <Color x:Key="AccentColor">#E0922E</Color>

    <Color x:Key="SuccessColor">#2E9C7E</Color>
    <Color x:Key="SuccessTintColor">#E6F4EF</Color>
    <Color x:Key="SuccessTextColor">#1B7A5E</Color>

    <Color x:Key="ErrorColor">#D2544A</Color>
    <Color x:Key="ErrorTintColor">#FBECEA</Color>
    <Color x:Key="ErrorTextColor">#B23B32</Color>

    <Color x:Key="WarnColor">#E0922E</Color>
    <Color x:Key="WarnTintColor">#FBF3E6</Color>
    <Color x:Key="WarnTextColor">#A9762A</Color>

    <Color x:Key="BackgroundColor">#F3F6FB</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceAltColor">#FAFBFD</Color>
    <Color x:Key="PanelColor">#F1F5FA</Color>

    <Color x:Key="SidebarColor">#16305A</Color>
    <Color x:Key="SidebarDarkColor">#102345</Color>
    <Color x:Key="SidebarTextColor">#AEC0DC</Color>
    <Color x:Key="SidebarMutedColor">#7F95BC</Color>
    <Color x:Key="TopbarStripColor">#13294D</Color>

    <Color x:Key="TextColor">#18222F</Color>
    <Color x:Key="TextSecondColor">#515E70</Color>
    <Color x:Key="MutedColor">#9AA6B5</Color>
    <Color x:Key="BorderColor">#E2E8F1</Color>
    <Color x:Key="InputBorderColor">#CFD8E3</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}" />
    <SolidColorBrush x:Key="PrimaryTintBrush" Color="{StaticResource PrimaryTintColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessTintBrush" Color="{StaticResource SuccessTintColor}" />
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}" />

    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="ErrorTintBrush" Color="{StaticResource ErrorTintColor}" />
    <SolidColorBrush x:Key="ErrorTextBrush" Color="{StaticResource ErrorTextColor}" />

    <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource WarnColor}" />
    <SolidColorBrush x:Key="WarnTintBrush" Color="{StaticResource WarnTintColor}" />
    <SolidColorBrush x:Key="WarnTextBrush" Color="{StaticResource WarnTextColor}" />

    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" />

    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}" />
    <SolidColorBrush x:Key="SidebarDarkBrush" Color="{StaticResource SidebarDarkColor}" />
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}" />
    <SolidColorBrush x:Key="SidebarMutedBrush" Color="{StaticResource SidebarMutedColor}" />
    <SolidColorBrush x:Key="TopbarStripBrush" Color="{StaticResource TopbarStripColor}" />

    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="TextSecondBrush" Color="{StaticResource TextSecondColor}" />
    <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}" />

    <!-- Pie/category chart palette (LiveChartsCore series, used from VM later) -->
    <SolidColorBrush x:Key="Chart1Brush" Color="#1F5AA8" />
    <SolidColorBrush x:Key="Chart2Brush" Color="#2E9C8E" />
    <SolidColorBrush x:Key="Chart3Brush" Color="#E0922E" />
    <SolidColorBrush x:Key="Chart4Brush" Color="#E2685A" />
    <SolidColorBrush x:Key="Chart5Brush" Color="#5A5BB8" />
    <SolidColorBrush x:Key="Chart6Brush" Color="#94A3B8" />

    <!-- Soft card elevation (opt-in via Effect="{StaticResource CardShadow}") -->
    <DropShadowEffect x:Key="CardShadow" Color="#142850" BlurRadius="18" ShadowDepth="3"
                      Direction="270" Opacity="0.08" />

    <!-- ============================================================
         Control styles — all keyed, applied per-view in B1–B5.
         ============================================================ -->

    <!-- Primary action button -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="B" Background="{StaticResource PrimaryBrush}" CornerRadius="10"
                            Padding="18,11" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="B" Property="Background" Value="#2A66B4" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="B" Property="Background" Value="{StaticResource PrimaryDarkBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="B" Property="Background" Value="#B9C6D8" />
                            <Setter TargetName="B" Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary (outline) button -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="#2A3645" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="B" Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                            BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1.5"
                            Padding="18,11" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="B" Property="Background" Value="{StaticResource PanelBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="B" Property="Opacity" Value="0.45" />
                            <Setter TargetName="B" Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger button (destructive: clear / delete) -->
    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="B" Background="{StaticResource ErrorBrush}" CornerRadius="10"
                            Padding="18,11" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="B" Property="Background" Value="#C0493C" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="B" Property="Background" Value="#B3433A" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="B" Property="Opacity" Value="0.5" />
                            <Setter TargetName="B" Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Subtle "danger outline" (e.g. clear logo/background) -->
    <Style x:Key="DangerOutlineButtonStyle" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ErrorTextBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="B" Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                            BorderBrush="#E8C9C5" BorderThickness="1.5" Padding="16,11" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="B" Property="Background" Value="{StaticResource ErrorTintBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="B" Property="Opacity" Value="0.45" />
                            <Setter TargetName="B" Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ghost / link button -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="B" Background="Transparent" CornerRadius="10" Padding="14,11">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="B" Property="Background" Value="{StaticResource PrimaryTintBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Card surface (Border) -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- Input text box -->
    <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="13,0" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="B" Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                            BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1.5"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="B" Property="BorderBrush" Value="{StaticResource PrimaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsReadOnly" Value="True">
                            <Setter TargetName="B" Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar nav item (ToggleButton bound to IsXSelected) -->
    <Style x:Key="SidebarNavToggleStyle" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="B" Background="Transparent" CornerRadius="10" Padding="12,11">
                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="B" Property="Background" Value="#1E3A66" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="B" Property="Background" Value="{StaticResource PrimaryBrush}" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
