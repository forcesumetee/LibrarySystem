<Window x:Class="LibraryAdminPC.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ยืนยัน"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource AppFontFamily}">
    <Border Style="{StaticResource CardStyle}" Margin="20" Padding="24" Width="420">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Border Width="40" Height="40" CornerRadius="20"
                        Background="{StaticResource ErrorTintBrush}" VerticalAlignment="Center">
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                               Foreground="{StaticResource ErrorTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="TxtTitle" Text="ยืนยันการลบ" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </StackPanel>

            <TextBlock x:Name="TxtMessage" Text="" TextWrapping="Wrap"
                       Foreground="{StaticResource TextSecondBrush}" FontSize="14" Margin="0,0,0,4"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button Content="ยกเลิก" Style="{StaticResource SecondaryButtonStyle}"
                        MinWidth="96" Margin="0,0,10,0" IsCancel="True"/>
                <Button x:Name="BtnConfirm" Content="ลบ" Style="{StaticResource DangerButtonStyle}"
                        MinWidth="96" IsDefault="True" Click="BtnConfirm_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
