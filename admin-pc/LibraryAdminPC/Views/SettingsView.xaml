<UserControl x:Class="LibraryAdminPC.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Tahoma">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ตั้งค่า"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1"
                   Text="ไฟล์ตั้งค่า:"
                   Foreground="#6B7280"/>
        <TextBlock Grid.Row="1"
                   Text="{Binding ConfigPath}"
                   Margin="0,18,0,0"
                   Foreground="#111827"
                   TextWrapping="Wrap"/>

        <!-- API Settings -->
        <Grid Grid.Row="2" Margin="0,16,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="API BaseUrl" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Height="34"
                         VerticalContentAlignment="Center"
                         Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="AdminKey" VerticalAlignment="Center"/>
                <PasswordBox x:Name="PwdAdminKey"
                             Grid.Column="1"
                             Height="34"
                             VerticalContentAlignment="Center"/>
            </Grid>
        </Grid>

        <!-- Kiosk URL Helper -->
        <Border Grid.Row="3" Background="#F9FAFB" CornerRadius="10" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="URL สำหรับจอ Kiosk (กรณีเชื่อมอัตโนมัติไม่ได้)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding KioskHint}" Foreground="#6B7280" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              Height="34"
                              ItemsSource="{Binding KioskUrls}"
                              SelectedItem="{Binding SelectedKioskUrl}"/>

                    <Button Grid.Column="1"
                            Content="คัดลอก"
                            Height="34"
                            Padding="14,0"
                            Margin="10,0,0,0"
                            Click="BtnCopyKioskUrl_Click"/>

                    <Button Grid.Column="2"
                            Content="รีเฟรช IP"
                            Height="34"
                            Padding="14,0"
                            Margin="10,0,0,0"
                            Click="BtnRefreshIps_Click"/>
                </Grid>

                <TextBlock Text="* หมายเหตุ: ถ้าจะให้จอ Kiosk เข้าได้ผ่าน IP นี้ ต้องรัน API Server แบบฟังทุก IP (เช่น --urls http://0.0.0.0:5269) และพอร์ต 5269 ต้องไม่ถูกบล็อกโดย Firewall"
                           Foreground="#6B7280"
                           FontSize="11"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Branding -->
        <Border Grid.Row="4" Background="#F9FAFB" CornerRadius="10" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="Branding (โลโก้ / พื้นหลัง)" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Logo" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Height="34" VerticalContentAlignment="Center" IsReadOnly="True"
                             Text="{Binding LogoPreviewPath}" Margin="0,0,10,0"/>
                    <Button Grid.Column="2" Content="เลือกไฟล์" Height="34" Padding="14,0" Margin="0,0,10,0" Click="BtnPickLogo_Click"/>
                    <Button Grid.Column="3" Content="ล้าง" Height="34" Padding="14,0" Click="BtnClearLogo_Click"/>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Background" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Height="34" VerticalContentAlignment="Center" IsReadOnly="True"
                             Text="{Binding BackgroundPreviewPath}" Margin="0,0,10,0"/>
                    <Button Grid.Column="2" Content="เลือกไฟล์" Height="34" Padding="14,0" Margin="0,0,10,0" Click="BtnPickBg_Click"/>
                    <Button Grid.Column="3" Content="ล้าง" Height="34" Padding="14,0" Click="BtnClearBg_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal">
                    <Button Content="บันทึก" Height="34" Padding="16,0" Margin="0,0,10,0" Click="BtnSave_Click"/>
                    <Button Content="ทดสอบเชื่อมต่อ" Height="34" Padding="16,0" Click="BtnTest_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Messages -->
        <StackPanel Grid.Row="5">
            <Border Background="#E8F3FF"
                    BorderBrush="#9CC7FF" BorderThickness="1"
                    CornerRadius="10" Padding="10" Margin="0,0,0,10"
                    Visibility="{Binding HasMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
            </Border>

            <Border Background="#FFF7E6"
                    BorderBrush="#FFD08A" BorderThickness="1"
                    CornerRadius="10" Padding="10" Margin="0,0,0,10"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding Error}" Foreground="#8A4B00" TextWrapping="Wrap"/>
            </Border>

            <Border Background="#80FFFFFF"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="220" Height="6" IsIndeterminate="True"/>
                    <TextBlock Text="กำลังทดสอบ..." Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

    </Grid>
</UserControl>