<UserControl x:Class="LibraryAdminPC.Views.BooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="320" />
        </Grid.ColumnDefinitions>

        <!-- LEFT -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtSearch"
                         Grid.Column="0"
                         Height="34"
                         VerticalContentAlignment="Center"
                         Margin="0,0,8,0"
                         TextChanged="TxtSearch_TextChanged"
                         ToolTip="ค้นหา (รหัส/ชื่อ/หมวด/สำนักพิมพ์/ชั้น)"/>

                <ComboBox x:Name="CmbCategory"
                          Grid.Column="1"
                          Height="34"
                          Margin="0,0,8,0"
                          SelectionChanged="CmbCategory_SelectionChanged"/>

                <Button x:Name="BtnRefresh"
                        Grid.Column="2"
                        Height="34"
                        Content="รีเฟรช"
                        Click="BtnRefresh_Click"/>
            </Grid>

            <DataGrid Grid.Row="2"
                      x:Name="BooksGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="BooksGrid_SelectionChanged"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="รหัส" Binding="{Binding RegNo}" Width="100"/>
                    <DataGridTextColumn Header="ชื่อหนังสือ" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="หมวดหมู่" Binding="{Binding Category}" Width="140"/>
                    <DataGridTextColumn Header="สำนักพิมพ์" Binding="{Binding Publisher}" Width="160"/>
                    <DataGridTextColumn Header="ชั้น" Binding="{Binding Shelf}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- RIGHT cover panel (เหมือนเดิมของคุณ) -->
        <Border Grid.Column="1" Margin="14,0,0,0"
                Padding="12" CornerRadius="10"
                Background="#FFF6F7F9" BorderBrush="#FFE5E7EB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="รูปหน้าปก" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock x:Name="TxtSelectedReg" Margin="0,6,0,8" Foreground="#FF6B7280" Text="ยังไม่ได้เลือกหนังสือ"/>

                <Border Height="220" CornerRadius="10" Background="White" BorderBrush="#FFE5E7EB" BorderThickness="1">
                    <Grid>
                        <Image x:Name="ImgCover" Stretch="UniformToFill"/>
                        <TextBlock x:Name="TxtNoCover" Text="ยังไม่มีรูปปก"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#FF9CA3AF"/>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="BtnUploadCover" Content="เปลี่ยนรูปปก" Width="120" Click="BtnUploadCover_Click" IsEnabled="False"/>
                    <Button x:Name="BtnDeleteCover" Content="ล้างรูปปก" Width="100" Margin="8,0,0,0" Click="BtnDeleteCover_Click" IsEnabled="False"/>
                </StackPanel>

                <TextBlock x:Name="TxtCoverStatus" Margin="0,10,0,0" Foreground="#FF6B7280" TextWrapping="Wrap"/>
                <TextBlock Text="แสดงรูปปกจาก Server" Foreground="#FF6B7280" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>