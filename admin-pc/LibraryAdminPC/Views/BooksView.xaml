<UserControl x:Class="LibraryAdminPC.Views.BooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:LibraryAdminPC.Converters"
             mc:Ignorable="d"
             FontFamily="{StaticResource AppFontFamily}"
             d:DesignHeight="640" d:DesignWidth="1100">

    <UserControl.Resources>
        <conv:CategoryToBrushConverter x:Key="CategoryToBrush"/>

        <!-- Search box with a REAL placeholder (hint text inside the template, shown only
             when empty). The caret stays in PART_ContentHost so it is always at the start
             when empty — the placeholder is never part of the Text. -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="B" Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                                BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1.5"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                           Foreground="{StaticResource MutedBrush}" IsHitTestVisible="False"
                                           VerticalAlignment="Center" HorizontalAlignment="Left" Margin="13,0,0,0"/>
                                <TextBlock x:Name="Placeholder"
                                           Text="ค้นหาจากชื่อ รหัส หมวดหมู่ หรือสำนักพิมพ์"
                                           Foreground="{StaticResource MutedBrush}" FontSize="13"
                                           IsHitTestVisible="False" VerticalAlignment="Center"
                                           HorizontalAlignment="Left" Margin="38,0,12,0"
                                           TextTrimming="CharacterEllipsis" Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"
                                              Margin="38,0,12,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="B" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- compact row action icon button (C2) -->
        <Style x:Key="RowIconBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="{StaticResource PanelBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="344" />
        </Grid.ColumnDefinitions>

        <!-- ===================== LEFT: search + table + pagination ===================== -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="18" VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- toolbar -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- search box with real in-template placeholder (TxtSearch + handler unchanged) -->
                    <TextBox x:Name="TxtSearch"
                             Grid.Column="0"
                             Margin="0,0,8,0"
                             Style="{StaticResource SearchBoxStyle}"
                             TextChanged="TxtSearch_TextChanged"
                             ToolTip="ค้นหา (รหัส/ชื่อ/หมวด/สำนักพิมพ์/ชั้น)"/>

                    <ComboBox x:Name="CmbCategory"
                              Grid.Column="1"
                              Height="40"
                              VerticalContentAlignment="Center"
                              FontFamily="{StaticResource AppFontFamily}"
                              FontSize="14"
                              Padding="10,0"
                              Margin="0,0,8,0"
                              SelectionChanged="CmbCategory_SelectionChanged"/>

                    <Button x:Name="BtnRefresh"
                            Grid.Column="2"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="96"
                            Content="รีเฟรช"
                            Click="BtnRefresh_Click"/>
                </Grid>

                <!-- table (MinHeight keeps the layout stable when results are few/none) -->
                <Grid Grid.Row="2" MinHeight="360">
                <DataGrid x:Name="BooksGrid"
                          VerticalAlignment="Top"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                          BorderThickness="0"
                          Background="Transparent"
                          RowBackground="{StaticResource SurfaceBrush}"
                          AlternatingRowBackground="{StaticResource SurfaceAltBrush}"
                          Foreground="{StaticResource TextBrush}"
                          FontSize="13"
                          RowHeight="48"
                          ColumnHeaderHeight="40"
                          SelectionUnit="FullRow"
                          CanUserResizeRows="False">
                    <DataGrid.Resources>
                        <!-- header -->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondBrush}"/>
                            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                        <!-- cell -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PrimaryTintBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <!-- ปก: color chip by category -->
                        <DataGridTemplateColumn Header="ปก" Width="56">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="30" Height="40" CornerRadius="6"
                                            HorizontalAlignment="Center"
                                            Background="{Binding Category, Converter={StaticResource CategoryToBrush}}">
                                        <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                   Foreground="White" Opacity="0.9"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="รหัส" Binding="{Binding RegNo}" Width="80"/>
                        <DataGridTextColumn Header="ชื่อหนังสือ" Binding="{Binding Title}" Width="*" MinWidth="150"/>

                        <!-- หมวดหมู่: colored badge -->
                        <DataGridTemplateColumn Header="หมวดหมู่" Width="128">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="9" Padding="9,3" HorizontalAlignment="Left"
                                            Background="{Binding Category, Converter={StaticResource CategoryToBrush}, ConverterParameter=tint}">
                                        <TextBlock Text="{Binding Category}" FontSize="12" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{Binding Category, Converter={StaticResource CategoryToBrush}}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="สำนักพิมพ์" Binding="{Binding Publisher}" Width="120"/>
                        <DataGridTextColumn Header="ชั้น" Binding="{Binding Shelf}" Width="64"/>

                        <!-- จัดการ: edit / delete per row -->
                        <DataGridTemplateColumn Header="จัดการ" Width="88">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource RowIconBtn}" Content="&#xE70F;"
                                                Foreground="{StaticResource PrimaryBrush}"
                                                ToolTip="แก้ไข" Click="BtnEditRow_Click"/>
                                        <Button Style="{StaticResource RowIconBtn}" Content="&#xE74D;"
                                                Foreground="{StaticResource ErrorBrush}"
                                                ToolTip="ลบ" Click="BtnDeleteRow_Click"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                    <!-- empty state (shown when there are no results) -->
                    <TextBlock x:Name="TxtEmpty" Text="ไม่พบหนังสือที่ค้นหา"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}" FontSize="14"
                               Visibility="Collapsed"/>
                </Grid>

                <!-- pagination bar (client-side) -->
                <Grid Grid.Row="3" Margin="0,12,0,0">
                    <TextBlock x:Name="TxtPageInfo" Text="แสดง 0–0 จาก 0" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondBrush}" FontSize="13"/>
                    <TextBlock x:Name="TxtStatus" Text="" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondBrush}" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnPrevPage" Style="{StaticResource SecondaryButtonStyle}"
                                Content="ก่อนหน้า" MinWidth="84" Click="BtnPrevPage_Click"/>
                        <TextBlock x:Name="TxtPageNum" Text="หน้า 1/1" VerticalAlignment="Center"
                                   Margin="12,0" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                        <Button x:Name="BtnNextPage" Style="{StaticResource SecondaryButtonStyle}"
                                Content="ถัดไป" MinWidth="84" Click="BtnNextPage_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ===================== RIGHT: add form + cover panel ===================== -->
        <StackPanel Grid.Column="1" Margin="16,0,0,0">

            <!-- ADD BOOK FORM -->
            <Border Style="{StaticResource CardStyle}" Padding="18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="32" Height="32" CornerRadius="9" Background="{StaticResource PrimaryTintBrush}">
                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="เพิ่มหนังสือใหม่" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <TextBlock Text="รหัส *" FontSize="12" Foreground="{StaticResource TextSecondBrush}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtNewRegNo" Style="{StaticResource InputTextBoxStyle}" Height="38"/>

                    <TextBlock Text="ชื่อหนังสือ *" FontSize="12" Foreground="{StaticResource TextSecondBrush}" Margin="0,10,0,4"/>
                    <TextBox x:Name="TxtNewTitle" Style="{StaticResource InputTextBoxStyle}" Height="38"/>

                    <TextBlock Text="หมวดหมู่" FontSize="12" Foreground="{StaticResource TextSecondBrush}" Margin="0,10,0,4"/>
                    <TextBox x:Name="TxtNewCategory" Style="{StaticResource InputTextBoxStyle}" Height="38"/>

                    <TextBlock Text="สำนักพิมพ์" FontSize="12" Foreground="{StaticResource TextSecondBrush}" Margin="0,10,0,4"/>
                    <TextBox x:Name="TxtNewPublisher" Style="{StaticResource InputTextBoxStyle}" Height="38"/>

                    <TextBlock Text="ชั้น" FontSize="12" Foreground="{StaticResource TextSecondBrush}" Margin="0,10,0,4"/>
                    <TextBox x:Name="TxtNewShelf" Style="{StaticResource InputTextBoxStyle}" Height="38"/>

                    <TextBlock Text="รูปปก (ไม่บังคับ)" FontSize="12" Foreground="{StaticResource TextSecondBrush}" Margin="0,10,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="เลือกรูป" Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnPickNewCover_Click"/>
                        <TextBlock x:Name="TxtNewCoverName" Grid.Column="1" Text="ยังไม่ได้เลือก"
                                   VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"
                                   Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <Button Content="บันทึก" Style="{StaticResource PrimaryButtonStyle}"
                                Click="BtnAddBook_Click"/>
                        <Button Content="ล้าง" Style="{StaticResource SecondaryButtonStyle}"
                                Margin="8,0,0,0" Click="BtnClearAddForm_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtAddStatus" Margin="0,12,0,0" TextWrapping="Wrap"
                               FontSize="12" Foreground="{StaticResource TextSecondBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
