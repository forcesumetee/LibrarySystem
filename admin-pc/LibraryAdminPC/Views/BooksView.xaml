<UserControl x:Class="LibraryAdminPC.Views.BooksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="{StaticResource AppFontFamily}"
             d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="336" />
        </Grid.ColumnDefinitions>

        <!-- ===================== LEFT: search + table ===================== -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- toolbar -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TxtSearch"
                             Grid.Column="0"
                             Style="{StaticResource InputTextBoxStyle}"
                             Margin="0,0,8,0"
                             TextChanged="TxtSearch_TextChanged"
                             ToolTip="ค้นหา (รหัส/ชื่อ/หมวด/สำนักพิมพ์/ชั้น)"/>

                    <ComboBox x:Name="CmbCategory"
                              Grid.Column="1"
                              Height="40"
                              VerticalContentAlignment="Center"
                              FontFamily="{StaticResource AppFontFamily}"
                              FontSize="14"
                              Padding="10,0"
                              Margin="0,0,8,0"
                              SelectionChanged="CmbCategory_SelectionChanged"/>

                    <Button x:Name="BtnRefresh"
                            Grid.Column="2"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="96"
                            Content="รีเฟรช"
                            Click="BtnRefresh_Click"/>
                </Grid>

                <!-- table -->
                <DataGrid Grid.Row="2"
                          x:Name="BooksGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="BooksGrid_SelectionChanged"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                          BorderThickness="0"
                          Background="Transparent"
                          RowBackground="{StaticResource SurfaceBrush}"
                          AlternatingRowBackground="{StaticResource SurfaceAltBrush}"
                          Foreground="{StaticResource TextBrush}"
                          FontSize="13"
                          RowHeight="40"
                          ColumnHeaderHeight="40"
                          SelectionUnit="FullRow"
                          CanUserResizeRows="False">
                    <DataGrid.Resources>
                        <!-- header -->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextSecondBrush}"/>
                            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                        <!-- cell -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PrimaryTintBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="รหัส" Binding="{Binding RegNo}" Width="84"/>
                        <DataGridTextColumn Header="ชื่อหนังสือ" Binding="{Binding Title}" Width="*" MinWidth="160"/>
                        <DataGridTextColumn Header="หมวดหมู่" Binding="{Binding Category}" Width="120"/>
                        <DataGridTextColumn Header="สำนักพิมพ์" Binding="{Binding Publisher}" Width="130"/>
                        <DataGridTextColumn Header="ชั้น" Binding="{Binding Shelf}" Width="72"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ===================== RIGHT: cover panel ===================== -->
        <Border Grid.Column="1" Margin="16,0,0,0" Style="{StaticResource CardStyle}" Padding="18">
            <StackPanel>
                <TextBlock Text="รูปหน้าปก" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock x:Name="TxtSelectedReg" Margin="0,6,0,12"
                           Foreground="{StaticResource TextSecondBrush}" Text="ยังไม่ได้เลือกหนังสือ"/>

                <Border Height="300" CornerRadius="12" Background="{StaticResource SurfaceAltBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                    <Grid>
                        <Image x:Name="ImgCover" Stretch="UniformToFill"/>
                        <TextBlock x:Name="TxtNoCover" Text="ยังไม่มีรูปปก"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                    <Button x:Name="BtnUploadCover" Content="เปลี่ยนรูปปก"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="BtnUploadCover_Click" IsEnabled="False"/>
                    <Button x:Name="BtnDeleteCover" Content="ล้างรูปปก"
                            Style="{StaticResource DangerOutlineButtonStyle}"
                            Margin="8,0,0,0" Click="BtnDeleteCover_Click" IsEnabled="False"/>
                </StackPanel>

                <TextBlock x:Name="TxtCoverStatus" Margin="0,14,0,0"
                           Foreground="{StaticResource TextSecondBrush}" TextWrapping="Wrap"/>
                <TextBlock Text="แสดงรูปปกจาก Server" Foreground="{StaticResource MutedBrush}"
                           FontSize="12" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
