<UserControl x:Class="LibraryAdminPC.Views.BrandingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LibraryAdminPC.Converters"
             FontFamily="{StaticResource AppFontFamily}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:PathToImageConverter x:Key="PathToImage"/>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="*"/>     <!-- logo + bg cards -->
            <RowDefinition Height="Auto"/>  <!-- actions -->
            <RowDefinition Height="Auto"/>  <!-- messages -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="โลโก้ &amp; พื้นหลัง" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="ตั้งค่าโลโก้และภาพพื้นหลังที่แสดงบนจอ Kiosk"
                       Foreground="{StaticResource TextSecondBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===================== Logo ===================== -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="โลโก้" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>

                    <Border Height="220" CornerRadius="12" Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                        <Grid>
                            <TextBlock Text="ยังไม่ได้เลือกโลโก้" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                            <Image Source="{Binding LogoPreviewPath, Converter={StaticResource PathToImage}}"
                                   Stretch="Uniform" Margin="14"/>
                        </Grid>
                    </Border>

                    <TextBox Style="{StaticResource InputTextBoxStyle}" IsReadOnly="True"
                             Text="{Binding LogoPreviewPath}" Margin="0,12,0,0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="เลือกไฟล์" Style="{StaticResource PrimaryButtonStyle}"
                                Click="BtnPickLogo_Click"/>
                        <Button Content="ล้าง" Style="{StaticResource DangerOutlineButtonStyle}"
                                Margin="10,0,0,0" Click="BtnClearLogo_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===================== Background ===================== -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="18" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="ภาพพื้นหลัง" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>

                    <Border Height="220" CornerRadius="12" Background="{StaticResource SurfaceAltBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                        <Grid>
                            <TextBlock Text="ยังไม่ได้เลือกพื้นหลัง" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                            <Image Source="{Binding BackgroundPreviewPath, Converter={StaticResource PathToImage}}"
                                   Stretch="UniformToFill"/>
                        </Grid>
                    </Border>

                    <TextBox Style="{StaticResource InputTextBoxStyle}" IsReadOnly="True"
                             Text="{Binding BackgroundPreviewPath}" Margin="0,12,0,0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="เลือกไฟล์" Style="{StaticResource PrimaryButtonStyle}"
                                Click="BtnPickBg_Click"/>
                        <Button Content="ล้าง" Style="{StaticResource DangerOutlineButtonStyle}"
                                Margin="10,0,0,0" Click="BtnClearBg_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== Save ===================== -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="บันทึก" Style="{StaticResource PrimaryButtonStyle}" Click="BtnSaveBranding_Click"/>
            <TextBlock Text="บันทึกแล้วจอ Kiosk จะอัปเดตโลโก้/พื้นหลังเมื่อ Sync ครั้งถัดไป"
                       VerticalAlignment="Center" Margin="14,0,0,0"
                       Foreground="{StaticResource MutedBrush}" FontSize="12"/>
        </StackPanel>

        <!-- ===================== Messages ===================== -->
        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <Border Background="{StaticResource SuccessTintBrush}"
                    BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="12"
                    Visibility="{Binding HasMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding Message}" Foreground="{StaticResource SuccessTextBrush}" TextWrapping="Wrap"/>
            </Border>
            <Border Background="{StaticResource ErrorTintBrush}"
                    BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1"
                    CornerRadius="10" Padding="12" Margin="0,8,0,0"
                    Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding Error}" Foreground="{StaticResource ErrorTextBrush}" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
