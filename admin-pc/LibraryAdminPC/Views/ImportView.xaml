<UserControl x:Class="LibraryAdminPC.Views.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Tahoma">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="นำเข้าข้อมูลหนังสือ" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="รองรับไฟล์ .csv / .xlsx / .db (SQLite) ผ่าน Server API"
                       Foreground="#6B7280" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- File row -->
        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#E5E7EB" BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Height="36"
                         VerticalContentAlignment="Center"
                         Text="{Binding FilePath}"
                         IsReadOnly="True"
                         Margin="0,0,10,0"/>

                <Button Grid.Column="1"
                        Content="เลือกไฟล์"
                        Height="36"
                        Padding="14,0"
                        Margin="0,0,8,0"
                        Click="BtnBrowse_Click"/>

                <Button Grid.Column="2"
                        Content="อัปโหลด"
                        Height="36"
                        Padding="14,0"
                        Margin="0,0,8,0"
                        Background="#2563EB"
                        Foreground="White"
                        BorderBrush="#1D4ED8"
                        Click="BtnUpload_Click"/>

                <Button Grid.Column="3"
                        Content="ไฟล์ตัวอย่าง"
                        Height="36"
                        Padding="14,0"
                        Margin="0,0,8,0"
                        Click="BtnExportTemplate_Click"
                        ToolTip="สร้างไฟล์ตัวอย่าง CSV เพื่อใช้อ้างอิง"/>

                <Button Grid.Column="4"
                        Content="ลบข้อมูลทั้งหมด"
                        Height="36"
                        Padding="14,0"
                        Background="#FEE2E2"
                        BorderBrush="#EF4444"
                        Foreground="#991B1B"
                        Click="BtnClearAll_Click"
                        ToolTip="ลบข้อมูลหนังสือทั้งหมดในฐานข้อมูลฝั่ง Server (ไม่สามารถกู้คืนได้)"/>
            </Grid>
        </Border>

        <!-- Tips -->
        <Border Grid.Row="2"
                Background="#F8FAFC"
                BorderBrush="#E5E7EB" BorderThickness="1"
                CornerRadius="12"
                Padding="12"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="คำแนะนำ" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock Text="• CSV ต้องมีคอลัมน์: reg_no, title, category, publisher, shelf" Foreground="#334155"/>
                <TextBlock Text="• แนะนำให้บันทึก CSV เป็น UTF-8 เพื่อไม่ให้ภาษาไทยเพี้ยน" Foreground="#334155"/>
                <TextBlock Text="• หลังอัปโหลดแล้ว Kiosk จะ Sync ข้อมูลจาก Server ได้ทันที" Foreground="#334155"/>
            </StackPanel>
        </Border>

        <!-- Result + Busy overlay -->
        <Grid Grid.Row="3">
            <Border Background="#E8F3FF"
                    BorderBrush="#9CC7FF" BorderThickness="1"
                    CornerRadius="12"
                    Padding="12"
                    Margin="0,0,0,10">
                <TextBlock Text="{Binding ResultText}" TextWrapping="Wrap"/>
            </Border>

            <Border Background="#80FFFFFF"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="260" Height="8" IsIndeterminate="True"/>
                    <TextBlock Text="กำลังประมวลผล..." Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>