<UserControl x:Class="LibraryAdminPC.Views.ImportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource AppFontFamily}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- drop zone + file -->
            <RowDefinition Height="Auto"/>  <!-- actions -->
            <RowDefinition Height="Auto"/>  <!-- tips -->
            <RowDefinition Height="*"/>     <!-- result -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="นำเข้าข้อมูลหนังสือ" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="รองรับไฟล์ .csv / .xlsx / .db (SQLite) ผ่าน Server API"
                       Foreground="{StaticResource TextSecondBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ===================== Drop zone + file ===================== -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18" Margin="0,0,0,14">
            <StackPanel>
                <!-- drag-drop zone (additive: DropZone_DragOver/DropZone_Drop set FilePath) -->
                <Border AllowDrop="True" DragOver="DropZone_DragOver" Drop="DropZone_Drop"
                        Background="{StaticResource SurfaceAltBrush}" CornerRadius="12" Height="148">
                    <Grid>
                        <Rectangle RadiusX="12" RadiusY="12" Fill="Transparent"
                                   Stroke="{StaticResource InputBorderBrush}" StrokeThickness="2"
                                   StrokeDashArray="5 4"/>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="46" Height="46" CornerRadius="12"
                                    Background="{StaticResource PrimaryTintBrush}" HorizontalAlignment="Center">
                                <TextBlock Text="⤓" FontSize="24" Foreground="{StaticResource PrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="ลากไฟล์ .csv / .xlsx / .db มาวางที่นี่"
                                       Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,12,0,2"/>
                            <TextBlock Text="หรือกดปุ่ม “เลือกไฟล์” ด้านล่าง"
                                       Foreground="{StaticResource MutedBrush}" FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- selected file path (read-only) -->
                <Grid Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Style="{StaticResource InputTextBoxStyle}"
                             Text="{Binding FilePath}"
                             IsReadOnly="True"
                             Margin="0,0,10,0"/>
                    <Button Grid.Column="1"
                            Content="เลือกไฟล์"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="BtnBrowse_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ===================== Actions ===================== -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
            <Button Content="อัปโหลด"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="BtnUpload_Click"/>
            <Button Content="ไฟล์ตัวอย่าง"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="10,0,0,0"
                    Click="BtnExportTemplate_Click"
                    ToolTip="สร้างไฟล์ตัวอย่าง CSV เพื่อใช้อ้างอิง"/>
            <Button Content="ลบข้อมูลทั้งหมด"
                    Style="{StaticResource DangerButtonStyle}"
                    Margin="10,0,0,0"
                    Click="BtnClearAll_Click"
                    ToolTip="ลบข้อมูลหนังสือทั้งหมดในฐานข้อมูลฝั่ง Server (ไม่สามารถกู้คืนได้)"/>
        </StackPanel>

        <!-- ===================== Tips ===================== -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="12" Padding="16" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="คำแนะนำ" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="• CSV ต้องมีคอลัมน์: reg_no, title, category, publisher, shelf"
                           Foreground="{StaticResource TextSecondBrush}" Margin="0,0,0,3"/>
                <TextBlock Text="• แนะนำให้บันทึก CSV เป็น UTF-8 เพื่อไม่ให้ภาษาไทยเพี้ยน"
                           Foreground="{StaticResource TextSecondBrush}" Margin="0,0,0,3"/>
                <TextBlock Text="• หลังอัปโหลดแล้ว Kiosk จะ Sync ข้อมูลจาก Server ได้ทันที"
                           Foreground="{StaticResource TextSecondBrush}"/>
            </StackPanel>
        </Border>

        <!-- ===================== Result + Busy overlay ===================== -->
        <Grid Grid.Row="4">
            <Border Style="{StaticResource CardStyle}"
                    Background="{StaticResource PrimaryTintBrush}"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    Padding="16">
                <TextBlock Text="{Binding ResultText}" TextWrapping="Wrap"
                           Foreground="{StaticResource TextBrush}"/>
            </Border>

            <Border Background="#CCFFFFFF" CornerRadius="14"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="260" Height="8" IsIndeterminate="True"
                                 Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="กำลังประมวลผล..." Margin="0,10,0,0" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
