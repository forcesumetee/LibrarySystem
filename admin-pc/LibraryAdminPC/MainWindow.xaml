<Window x:Class="LibraryAdminPC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LibraryAdminPC.Views"
        Title="ระบบผู้ดูแลห้องสมุด" Height="820" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6FA"
        FontFamily="Tahoma">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#111827" Padding="16">
            <!-- Use Grid to lock footer at bottom -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header -->
                    <RowDefinition Height="Auto"/>  <!-- Menu -->
                    <RowDefinition Height="*"/>     <!-- Spacer -->
                    <RowDefinition Height="Auto"/>  <!-- Status -->
                    <RowDefinition Height="Auto"/>  <!-- Company Footer -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="ผู้ดูแลห้องสมุด"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="คอนโซลเจ้าหน้าที่ (Admin-PC)"
                               Foreground="#9CA3AF"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Menu -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <ToggleButton Content="แดชบอร์ด"
                                  Click="BtnDashboard_Click"
                                  Height="40"
                                  Margin="0,0,0,10"
                                  Background="#1F2937"
                                  Foreground="White"
                                  BorderBrush="#374151"
                                  FontWeight="SemiBold"
                                  IsChecked="{Binding IsDashboardSelected}"/>

                    <ToggleButton Content="หนังสือ"
                                  Click="BtnBooks_Click"
                                  Height="40"
                                  Margin="0,0,0,10"
                                  Background="#111827"
                                  Foreground="White"
                                  BorderBrush="#374151"
                                  IsChecked="{Binding IsBooksSelected}"/>

                    <ToggleButton Content="นำเข้า"
                                  Click="BtnImport_Click"
                                  Height="40"
                                  Margin="0,0,0,10"
                                  Background="#111827"
                                  Foreground="White"
                                  BorderBrush="#374151"
                                  IsChecked="{Binding IsImportSelected}"/>

                    <ToggleButton Content="ตั้งค่า"
                                  Click="BtnSettings_Click"
                                  Height="40"
                                  Margin="0,0,0,10"
                                  Background="#111827"
                                  Foreground="White"
                                  BorderBrush="#374151"
                                  IsChecked="{Binding IsSettingsSelected}"/>
                </StackPanel>

                <!-- Status (above company footer) -->
                <StackPanel Grid.Row="3" Margin="0,16,0,0">
                    <Separator Background="#374151" />
                    <TextBlock Text="สถานะ"
                               Foreground="#9CA3AF"
                               Margin="0,12,0,4"
                               FontSize="12"/>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="White"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding ApiBaseUrlText}"
                               Foreground="#9CA3AF"
                               FontSize="11"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Company Footer (LOCKED bottom-left) -->
                <StackPanel Grid.Row="4" Margin="0,16,0,0">
                    <TextBlock Text="NTY MULTIMEDIA CO.,LTD."
                               Foreground="#9CA3AF"
                               FontSize="11"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,2"/>
                    <TextBlock Text="© 2026 All rights reserved."
                               Foreground="#6B7280"
                               FontSize="10"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,0"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Main Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PageTitle}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>
                        <TextBlock Text="{Binding PageSubtitle}"
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- License badge -->
                    <Button Grid.Column="1"
                            Height="32"
                            MinWidth="170"
                            Padding="12,0"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Background="{Binding LicenseBadgeBackground}"
                            Foreground="{Binding LicenseBadgeForeground}"
                            BorderBrush="{Binding LicenseBadgeBorderBrush}"
                            ToolTip="{Binding LicenseBadgeToolTip}"
                            Click="BtnLicenseBadge_Click">
                        <TextBlock Text="{Binding LicenseBadgeText}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Button>

                    <Button Grid.Column="2"
                            Content="รีเฟรชสถานะ"
                            Click="BtnRefreshStatus_Click"
                            Height="32"
                            Padding="12,0"
                            VerticalAlignment="Center"
                            Background="#2563EB"
                            Foreground="White"
                            BorderBrush="#2563EB"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Border Grid.Row="1" Margin="16" Background="White" CornerRadius="12" Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ContentControl x:Name="MainContent"/>
                </ScrollViewer>
            </Border>
        </Grid>

    </Grid>
</Window>